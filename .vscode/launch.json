{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch InsTK.Server (HTTPS)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build InsTK.Server",
      "program": "${workspaceFolder}/InsTK.Server/bin/Debug/net10.0/InsTK.Server.dll",
      "cwd": "${workspaceFolder}/InsTK.Server",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "https://instk.dev.localhost:7016/"
      }
    }
  ]
}
