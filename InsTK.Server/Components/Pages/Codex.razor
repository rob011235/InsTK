@page "/codex"
@rendermode InteractiveServer

@using InsTK.Server.Services.Ollama
@inject InsTK.Server.Services.Ollama.IOllamaChatService OllamaChatService

<PageTitle>Ollama Console</PageTitle>

<div class="codex-page">
    <section class="codex-hero">
        <p class="codex-eyebrow">Local model console</p>
        <h1>Ollama</h1>
        <p class="codex-description">
            Send a prompt to the configured local Ollama model and review the response here.
        </p>
    </section>

    <section class="codex-console">
        <div class="codex-console__meta">
            <span class="codex-console__chip">Endpoint: @configuration.BaseUrl</span>
            <span class="codex-console__chip">Model: @configuration.Model</span>
        </div>

        <label class="form-label" for="codex-prompt">Prompt</label>
        <InputTextArea id="codex-prompt"
                       class="form-control codex-console__input"
                       @bind-Value="prompt"
                       placeholder="Ask Ollama to explain code, summarize an error, or draft a change." />

        <div class="codex-console__actions">
            <button type="button" class="btn btn-primary" @onclick="SubmitPromptAsync" disabled="@isBusyOrPromptEmpty">
                @(isBusy ? "Sending..." : "Send")
            </button>
            <button type="button" class="btn btn-outline-secondary" @onclick="ClearPrompt" disabled="@isBusyOrPromptEmpty">
                Clear
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger mb-0" role="alert">@errorMessage</div>
        }
    </section>

    <section class="codex-transcript">
        <div class="d-flex justify-content-between align-items-center gap-3">
            <h2 class="h4 mb-0">Transcript</h2>
            @if (entries.Count > 0)
            {
                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearTranscript" disabled="@isBusy">Clear Transcript</button>
            }
        </div>

        @if (entries.Count == 0)
        {
            <div class="codex-empty-state">
                No prompts submitted yet.
            </div>
        }
        else
        {
            <div class="codex-transcript__list">
                @foreach (var entry in entries)
                {
                    <article class="codex-entry codex-entry--@entry.RoleClass">
                        <header class="codex-entry__header">
                            <span class="codex-entry__role">@entry.RoleLabel</span>
                            <time class="codex-entry__time">@entry.SubmittedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</time>
                        </header>
                        <p class="codex-entry__prompt">@entry.Content</p>
                    </article>
                }
            </div>
        }
    </section>
</div>

@code {
    private readonly List<TranscriptEntry> entries = [];
    private string prompt = string.Empty;
    private string? errorMessage;
    private bool isBusy;
    private OllamaChatConfiguration configuration = new("http://127.0.0.1:11434", "qwen3-coder:30b");

    private bool isBusyOrPromptEmpty => isBusy || string.IsNullOrWhiteSpace(prompt);

    protected override async Task OnInitializedAsync()
    {
        configuration = await OllamaChatService.GetConfigurationAsync();
    }

    private async Task SubmitPromptAsync()
    {
        var trimmedPrompt = prompt.Trim();

        if (string.IsNullOrWhiteSpace(trimmedPrompt))
        {
            return;
        }

        isBusy = true;
        errorMessage = null;
        entries.Insert(0, TranscriptEntry.User(trimmedPrompt));
        prompt = string.Empty;

        try
        {
            var response = await OllamaChatService.GenerateAsync(trimmedPrompt);
            entries.Insert(0, TranscriptEntry.Assistant(response.Response));
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void ClearPrompt()
    {
        prompt = string.Empty;
    }

    private void ClearTranscript()
    {
        entries.Clear();
        errorMessage = null;
    }

    private sealed record TranscriptEntry(string RoleLabel, string RoleClass, string Content, DateTimeOffset SubmittedAt)
    {
        public static TranscriptEntry User(string content) => new("You", "user", content, DateTimeOffset.UtcNow);

        public static TranscriptEntry Assistant(string content) => new("Ollama", "assistant", content, DateTimeOffset.UtcNow);
    }
}
