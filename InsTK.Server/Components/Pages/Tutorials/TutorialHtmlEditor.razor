@using System.Linq.Expressions
@using System.Net

@inject IWebHostEnvironment HostEnvironment

<div class="mb-3">
    <label class="form-label">@Label</label>

    <div class="tutorial-html-workbench">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
            <span class="small text-muted">
                Edit the tutorial body as HTML-rich content. Uploaded images are saved locally and inserted directly
                into the editor.
            </span>

            <div class="d-flex flex-column align-items-stretch gap-2">
                <InputFile OnChange="OnImageSelectedAsync" accept="image/png,image/jpeg,image/gif"
                           class="form-control form-control-sm" />

                @if (!string.IsNullOrWhiteSpace(uploadStatusMessage))
                {
                    <span class="small @(uploadHadError ? "text-danger" : "text-muted")">@uploadStatusMessage</span>
                }
            </div>
        </div>

        <div class="tutorial-html-layout">
            <div class="tutorial-html-layout__editor">
                <div class="tutorial-html-editor__surface">
                    <SfRichTextEditor @ref="editorRef" CssClass="tutorial-html-editor" Height="@MinHeight"
                                      Placeholder="@Placeholder" SaveInterval="300" ShowCharCount="true" AutoSaveOnIdle="true"
                                      EnableTabKey="true" EnableXhtml="true"
                                      Value="@editorValue">
                        <RichTextEditorToolbarSettings Items="@toolbarItems" />
                        <RichTextEditorEvents ValueChange="OnEditorValueChanged" />
                        <RichTextEditorQuickToolbarSettings Text="@TextQuickToolbarItems" ShowOnRightClick="true"
                                                            Table="@TableQuickToolbarItems" />
                        <RichTextEditorSlashMenuSettings Enable="true" Items="@slashmenuItems" />
                    </SfRichTextEditor>
                </div>
            </div>
        </div>
    </div>

    <ValidationMessage For="ResolvedValueExpression" />
</div>

@code {
    private const long MaxImageBytes = 2 * 1024 * 1024;

    private static readonly HashSet<string> AllowedExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        ".png",
        ".jpg",
        ".jpeg",
        ".gif"
    };

    private static readonly List<ToolbarItemModel> toolbarItems =
    [
        new ToolbarItemModel() { Command = ToolbarCommand.Undo },
        new ToolbarItemModel() { Command = ToolbarCommand.Redo },
        new ToolbarItemModel() { Command = ToolbarCommand.Separator },
        new ToolbarItemModel() { Command = ToolbarCommand.Formats },
        new ToolbarItemModel() { Command = ToolbarCommand.Bold },
        new ToolbarItemModel() { Command = ToolbarCommand.Italic },
        new ToolbarItemModel() { Command = ToolbarCommand.Underline },
        new ToolbarItemModel() { Command = ToolbarCommand.InlineCode },
        new ToolbarItemModel() { Command = ToolbarCommand.Separator },
        new ToolbarItemModel() { Command = ToolbarCommand.CreateLink },
        new ToolbarItemModel() { Command = ToolbarCommand.Image },
        new ToolbarItemModel() { Command = ToolbarCommand.CreateTable },
        new ToolbarItemModel() { Command = ToolbarCommand.CodeBlock },
        new ToolbarItemModel() { Command = ToolbarCommand.Blockquote },
        new ToolbarItemModel() { Command = ToolbarCommand.HorizontalLine },
        new ToolbarItemModel() { Command = ToolbarCommand.Separator },
        new ToolbarItemModel() { Command = ToolbarCommand.UnorderedList },
        new ToolbarItemModel() { Command = ToolbarCommand.OrderedList },
        new ToolbarItemModel() { Command = ToolbarCommand.Indent },
        new ToolbarItemModel() { Command = ToolbarCommand.Outdent },
        new ToolbarItemModel() { Command = ToolbarCommand.Separator },
        new ToolbarItemModel() { Command = ToolbarCommand.ClearFormat },
        new ToolbarItemModel() { Command = ToolbarCommand.SourceCode }
    ];

    private static readonly List<ToolbarItemModel> TextQuickToolbarItems =
    [
        new ToolbarItemModel() { Command = ToolbarCommand.Formats },
        new ToolbarItemModel() { Command = ToolbarCommand.Separator },
        new ToolbarItemModel() { Command = ToolbarCommand.Bold },
        new ToolbarItemModel() { Command = ToolbarCommand.Italic },
        new ToolbarItemModel() { Command = ToolbarCommand.Underline },
        new ToolbarItemModel() { Command = ToolbarCommand.Separator },
        new ToolbarItemModel() { Command = ToolbarCommand.CreateLink },
        new ToolbarItemModel() { Command = ToolbarCommand.Image },
        new ToolbarItemModel() { Command = ToolbarCommand.CreateTable },
        new ToolbarItemModel() { Command = ToolbarCommand.Blockquote },
        new ToolbarItemModel() { Command = ToolbarCommand.Separator },
        new ToolbarItemModel() { Command = ToolbarCommand.UnorderedList },
        new ToolbarItemModel() { Command = ToolbarCommand.OrderedList },
        new ToolbarItemModel() { Command = ToolbarCommand.Indent },
        new ToolbarItemModel() { Command = ToolbarCommand.Outdent }
    ];

    private static readonly List<TableToolbarItemModel> TableQuickToolbarItems =
    [
        new TableToolbarItemModel() { Command = TableToolbarCommand.TableHeader },
        new TableToolbarItemModel() { Command = TableToolbarCommand.TableRemove },
        new TableToolbarItemModel() { Command = TableToolbarCommand.Separator },
        new TableToolbarItemModel() { Command = TableToolbarCommand.TableRows },
        new TableToolbarItemModel() { Command = TableToolbarCommand.TableColumns },
        new TableToolbarItemModel() { Command = TableToolbarCommand.TableCell },
        new TableToolbarItemModel() { Command = TableToolbarCommand.Separator },
        new TableToolbarItemModel() { Command = TableToolbarCommand.TableEditProperties },
        new TableToolbarItemModel() { Command = TableToolbarCommand.Styles },
        new TableToolbarItemModel() { Command = TableToolbarCommand.BackgroundColor },
        new TableToolbarItemModel() { Command = TableToolbarCommand.Alignments },
        new TableToolbarItemModel() { Command = TableToolbarCommand.TableCellVerticalAlign }
    ];

    private static readonly List<SlashMenuItemModel> slashmenuItems =
    [
        new SlashMenuItemModel() { Command = SlashMenuCommand.Paragraph, Text = "Paragraph" },
        new SlashMenuItemModel() { Command = SlashMenuCommand.Heading1, Text = "Heading 1" },
        new SlashMenuItemModel() { Command = SlashMenuCommand.Heading2, Text = "Heading 2" },
        new SlashMenuItemModel() { Command = SlashMenuCommand.Heading3, Text = "Heading 3" },
        new SlashMenuItemModel() { Command = SlashMenuCommand.OrderedList, Text = "Numbered list" },
        new SlashMenuItemModel() { Command = SlashMenuCommand.UnorderedList, Text = "Bulleted list" },
        new SlashMenuItemModel() { Command = SlashMenuCommand.Blockquote, Text = "Blockquote" },
        new SlashMenuItemModel() { Command = SlashMenuCommand.CodeBlock, Text = "Code block" },
        new SlashMenuItemModel() { Command = SlashMenuCommand.Table, Text = "Table" },
        new SlashMenuItemModel() { Command = SlashMenuCommand.Image, Text = "Image" },
        new SlashMenuItemModel() { Command = SlashMenuCommand.Link, Text = "Link" }
    ];

    private SfRichTextEditor? editorRef;
    private string editorValue = string.Empty;
    private string? uploadStatusMessage;
    private bool uploadHadError;
    private FieldIdentifier? fieldIdentifier;

    [Parameter, EditorRequired]
    public string Label { get; set; } = string.Empty;

    [Parameter]
    public string? Value { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string> ValueChanged { get; set; }

    [Parameter]
    public Expression<Func<string?>>? ValueExpression { get; set; }

    [Parameter]
    public string Placeholder { get; set; } = string.Empty;

    [Parameter]
    public string MinHeight { get; set; } = "250px";

    [CascadingParameter]
    private EditContext? EditContext { get; set; }

    private Expression<Func<string?>> ResolvedValueExpression => ValueExpression ?? (() => Value);

    protected override void OnParametersSet()
    {
        if (ValueExpression != null)
        {
            fieldIdentifier = FieldIdentifier.Create(ValueExpression);
        }

        var normalizedValue = Value ?? string.Empty;
        if (!string.Equals(editorValue, normalizedValue, StringComparison.Ordinal))
        {
            editorValue = normalizedValue;
        }
    }

    private async Task OnEditorValueChanged(Syncfusion.Blazor.RichTextEditor.ChangeEventArgs args)
    {
        var normalizedValue = args.Value ?? string.Empty;
        if (string.Equals(editorValue, normalizedValue, StringComparison.Ordinal))
        {
            return;
        }

        editorValue = normalizedValue;
        uploadStatusMessage = null;
        uploadHadError = false;

        await ValueChanged.InvokeAsync(editorValue);

        if (fieldIdentifier is FieldIdentifier currentFieldIdentifier)
        {
            EditContext?.NotifyFieldChanged(currentFieldIdentifier);
        }
    }

    private async Task OnImageSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        var extension = Path.GetExtension(file.Name ?? string.Empty);
        if (!AllowedExtensions.Contains(extension))
        {
            uploadStatusMessage = "Only PNG, JPG, JPEG, and GIF images are allowed.";
            uploadHadError = true;
            return;
        }

        if (file.Size > MaxImageBytes)
        {
            uploadStatusMessage = "Image must be 2 MB or smaller.";
            uploadHadError = true;
            return;
        }

        var uploadsRoot = Path.Combine(HostEnvironment.WebRootPath, "uploads");
        Directory.CreateDirectory(uploadsRoot);

        var fileName = $"{Guid.NewGuid():N}{extension.ToLowerInvariant()}";
        var physicalPath = Path.Combine(uploadsRoot, fileName);

        await using (var targetStream = File.Create(physicalPath))
        await using (var sourceStream = file.OpenReadStream(MaxImageBytes))
        {
            await sourceStream.CopyToAsync(targetStream);
        }

        var altText = WebUtility.HtmlEncode(Path.GetFileNameWithoutExtension(file.Name));
        var imageHtml = $"<p><img src=\"/uploads/{fileName}\" alt=\"{altText}\" /></p>";
        editorValue = string.IsNullOrWhiteSpace(editorValue)
            ? imageHtml
            : $"{editorValue}{Environment.NewLine}{imageHtml}";

        uploadStatusMessage = $"Uploaded {file.Name} and inserted the image.";
        uploadHadError = false;

        if (editorRef != null)
        {
            await editorRef.RefreshUIAsync();
        }

        await ValueChanged.InvokeAsync(editorValue);

        if (fieldIdentifier is FieldIdentifier currentFieldIdentifier)
        {
            EditContext?.NotifyFieldChanged(currentFieldIdentifier);
        }
    }
}
