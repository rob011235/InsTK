@using InsTK.Shared.Models.Tutorials

<EditForm Model="Model" OnValidSubmit="OnSaveRequested" FormName="tutorialBrightspaceAssignmentForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-4">
        <button type="submit" class="btn btn-outline-primary me-2">Save</button>

        <button type="button" class="btn btn-outline-dark me-2" @onclick="OnExportRequested">
            Export
        </button>

        <button type="button" class="btn btn-outline-secondary" @onclick="OnReturnToListRequested">
            Return to List
        </button>
    </div>

    <div class="mb-3">
        <h4>Brightspace Assignment Draft</h4>
        <p class="text-muted mb-0">
            Draft the assignment shell that will be copied into Brightspace.
        </p>
    </div>

    <div class="row g-3">
        <div class="col-md-8">
            <label class="form-label">Assignment Title</label>
            <InputText id="assignment-title" class="form-control" Value="@Model.BrightspaceAssignmentTitle"
                       ValueChanged="OnAssignmentTitleChanged"
                       ValueExpression="() => Model.BrightspaceAssignmentTitle" />
            <div class="form-text">
                Leave blank to use the tutorial title.
            </div>
        </div>

        <div class="col-md-4">
            <label class="form-label">Points</label>
            <InputNumber class="form-control" @bind-Value="Model.BrightspacePoints" />
        </div>

        <div class="col-12">
            <label class="form-label">Assignment Instructions</label>
            <InputTextArea id="assignment-instructions" class="form-control" style="min-height: 180px;"
                           @bind-Value="Model.BrightspaceAssignmentInstructions" />
            <div class="form-text">
                These are instructor-facing assignment directions for Brightspace.
            </div>
        </div>

        <div class="col-12">
            <label class="form-label">Submission Instructions</label>
            <InputTextArea class="form-control" style="min-height: 120px;"
                           @bind-Value="Model.BrightspaceSubmissionInstructions" />
            <div class="form-text">
                Example: Submit your GitHub repository URL and branch name in the Brightspace comments.
            </div>
        </div>
    </div>

    <hr />

    <div class="mt-3 pb-4">
        <button type="submit" class="btn btn-outline-primary me-2">Save</button>

        <button type="button" class="btn btn-outline-dark me-2" @onclick="OnExportRequested">
            Export
        </button>

        <button type="button" class="btn btn-outline-secondary" @onclick="OnReturnToListRequested">
            Return to List
        </button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public TutorialDefinition Model { get; set; } = null!;

    [Parameter, EditorRequired]
    public EventCallback<string> OnAssignmentTitleChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback OnSaveRequested { get; set; }

    [Parameter, EditorRequired]
    public EventCallback OnExportRequested { get; set; }

    [Parameter, EditorRequired]
    public EventCallback OnReturnToListRequested { get; set; }
}
