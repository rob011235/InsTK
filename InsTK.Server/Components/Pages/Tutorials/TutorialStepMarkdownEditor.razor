@using Blazorise
@using System.IO
@using Microsoft.AspNetCore.Hosting

@inject IWebHostEnvironment WebHostEnvironment

<div class="mb-3">
    <label class="form-label">Instruction Markdown</label>

    <div class="tutorial-markdown-workbench">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div class="small text-muted">
                Preview uses the same Markdig renderer as tutorial preview and export.
            </div>

            <div class="d-flex align-items-center gap-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="OpenImagePickerAsync">
                    Upload Image
                </button>

                <span class="small text-muted">PNG, JPG, JPEG, GIF up to 2 MB</span>
            </div>
        </div>

        <FileInput @ref="imageInput"
                   class="tutorial-markdown-hidden-input"
                   Filter="image/png,image/jpeg,image/gif"
                   Changed="OnImageSelectedAsync" />

        <div class="tutorial-markdown-editor mb-3">
            <Markdown @ref="markdownEditor"
                      Value="@Step.InstructionMarkdown"
                      ValueChanged="OnMarkdownChangedAsync"
                      MinHeight="250px"
                      MaxUploadImageChunkSize="20480"
                      Placeholder="Write the student-facing markdown for this step." />
        </div>

        @if (!string.IsNullOrWhiteSpace(uploadError))
        {
            <div class="alert alert-danger py-2 mb-3" role="alert">
                @uploadError
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(uploadMessage))
        {
            <div class="alert alert-success py-2 mb-3" role="status">
                @uploadMessage
            </div>
        }

        <section class="tutorial-markdown-preview">
            <div class="border-bottom px-3 py-2 bg-light small text-uppercase text-muted fw-semibold">
                Live Preview
            </div>

            <div class="tutorial-markdown-preview__body">
                @if (string.IsNullOrWhiteSpace(Step.InstructionMarkdown))
                {
                    <p class="text-muted mb-0">Preview will appear as you write markdown.</p>
                }
                else
                {
                    <div>@((MarkupString)markdownHtml)</div>
                }
            </div>
        </section>
    </div>
</div>

@code {
    private const long MaxImageBytes = 2 * 1024 * 1024;

    private static readonly HashSet<string> AllowedImageExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        ".png",
        ".jpg",
        ".jpeg",
        ".gif"
    };

    [Parameter, EditorRequired]
    public TutorialStep Step { get; set; } = default!;

    private Blazorise.Markdown.Markdown? markdownEditor;
    private FileInput? imageInput;
    private string markdownHtml = string.Empty;
    private string? uploadError;
    private string? uploadMessage;
    private string? lastRenderedMarkdown;

    protected override void OnParametersSet()
    {
        var markdown = Step.InstructionMarkdown ?? string.Empty;

        if (!string.Equals(lastRenderedMarkdown, markdown, StringComparison.Ordinal))
        {
            markdownHtml = TutorialContentFormatter.RenderMarkdown(markdown);
            lastRenderedMarkdown = markdown;
        }
    }

    private Task OnMarkdownChangedAsync(string value)
    {
        Step.InstructionMarkdown = value ?? string.Empty;
        markdownHtml = TutorialContentFormatter.RenderMarkdown(Step.InstructionMarkdown);
        lastRenderedMarkdown = Step.InstructionMarkdown;
        uploadMessage = null;

        return Task.CompletedTask;
    }

    private async Task OpenImagePickerAsync()
    {
        uploadError = null;
        uploadMessage = null;

        if (imageInput != null)
        {
            await imageInput.ShowPicker();
        }
    }

    private async Task OnImageSelectedAsync(FileChangedEventArgs eventArgs)
    {
        uploadError = null;
        uploadMessage = null;

        var file = eventArgs.Files.FirstOrDefault();
        if (file == null)
        {
            return;
        }

        var extension = Path.GetExtension(file.Name ?? string.Empty);
        if (!AllowedImageExtensions.Contains(extension))
        {
            uploadError = "Only PNG, JPG, JPEG, and GIF images are allowed.";
            await ResetImageInputAsync();
            return;
        }

        if (file.Size > MaxImageBytes)
        {
            uploadError = "Image must be 2 MB or smaller.";
            await ResetImageInputAsync();
            return;
        }

        var uploadsRoot = Path.Combine(WebHostEnvironment.WebRootPath, "uploads");
        Directory.CreateDirectory(uploadsRoot);

        var fileName = $"{Guid.NewGuid():N}{extension.ToLowerInvariant()}";
        var physicalPath = Path.Combine(uploadsRoot, fileName);

        await using (var targetStream = File.Create(physicalPath))
        await using (var sourceStream = file.OpenReadStream(MaxImageBytes))
        {
            await sourceStream.CopyToAsync(targetStream);
        }

        var imageUrl = $"/uploads/{fileName}";
        var markdownSnippet = $"![alt text]({imageUrl})";
        var updatedMarkdown = AppendMarkdownSnippet(Step.InstructionMarkdown, markdownSnippet);

        Step.InstructionMarkdown = updatedMarkdown;
        markdownHtml = TutorialContentFormatter.RenderMarkdown(updatedMarkdown);
        lastRenderedMarkdown = updatedMarkdown;
        uploadMessage = $"Inserted image URL {imageUrl} into markdown.";

        if (markdownEditor != null)
        {
            await markdownEditor.SetValueAsync(updatedMarkdown);
        }

        await ResetImageInputAsync();
    }

    private async Task ResetImageInputAsync()
    {
        if (imageInput != null)
        {
            await imageInput.Reset();
        }
    }

    private static string AppendMarkdownSnippet(string? existingMarkdown, string snippet)
    {
        var current = existingMarkdown ?? string.Empty;

        if (string.IsNullOrWhiteSpace(current))
        {
            return snippet;
        }

        current = current.TrimEnd();

        return $"{current}{Environment.NewLine}{Environment.NewLine}{snippet}";
    }
}
