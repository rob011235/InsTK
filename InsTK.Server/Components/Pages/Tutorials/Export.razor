@page "/tutorials/{Id:guid}/export"
@rendermode InteractiveServer

@using System.Net
@using InsTK.Server.Data
@using InsTK.Shared.Models.Tutorials
@using Microsoft.EntityFrameworkCore

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Tutorial Export</PageTitle>

@if (tutorial == null)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">Export @tutorial.Title</h3>
            <p class="text-muted mb-0">Student-facing content only. Reference code and grading hints are excluded.</p>
        </div>

        <div>
            <button type="button" class="btn btn-outline-secondary me-2" @onclick="BackToEdit">Back to Edit</button>
            <button type="button" class="btn btn-outline-primary" @onclick="OpenPreview">Preview</button>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0">WordPress HTML</h4>
                        <a class="btn btn-sm btn-dark" href="@(BuildDownloadHref(htmlExport, "text/html"))" download="@(GetFileName(".html"))">
                            Download HTML
                        </a>
                    </div>

                    <textarea class="form-control font-monospace" style="min-height: 320px;" readonly>@htmlExport</textarea>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0">WordPress Markdown</h4>
                        <a class="btn btn-sm btn-outline-dark" href="@(BuildDownloadHref(markdownExport, "text/markdown"))" download="@(GetFileName(".md"))">
                            Download Markdown
                        </a>
                    </div>

                    <textarea class="form-control font-monospace" style="min-height: 320px;" readonly>@markdownExport</textarea>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private TutorialDefinition? tutorial;
    private string htmlExport = string.Empty;
    private string markdownExport = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        tutorial = await db.Tutorials
            .AsNoTracking()
            .Include(t => t.Steps)
            .FirstOrDefaultAsync(t => t.Id == Id);

        if (tutorial == null)
        {
            Nav.NavigateTo("/tutorials");
            return;
        }

        htmlExport = TutorialContentFormatter.BuildWordPressHtml(tutorial);
        markdownExport = TutorialContentFormatter.BuildWordPressMarkdown(tutorial);
    }

    private void BackToEdit()
    {
        Nav.NavigateTo($"/tutorials/edit/{Id}");
    }

    private void OpenPreview()
    {
        Nav.NavigateTo($"/tutorials/{Id}/preview");
    }

    private string BuildDownloadHref(string content, string contentType)
    {
        return $"data:{contentType};charset=utf-8,{WebUtility.UrlEncode(content)}";
    }

    private string GetFileName(string extension)
    {
        var slug = new string((tutorial?.Title ?? "tutorial")
            .ToLowerInvariant()
            .Select(ch => char.IsLetterOrDigit(ch) ? ch : '-')
            .ToArray());

        while (slug.Contains("--", StringComparison.Ordinal))
        {
            slug = slug.Replace("--", "-", StringComparison.Ordinal);
        }

        slug = slug.Trim('-');

        if (string.IsNullOrWhiteSpace(slug))
        {
            slug = "tutorial";
        }

        return $"{slug}{extension}";
    }
}
