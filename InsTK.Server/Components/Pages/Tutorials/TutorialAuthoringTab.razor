@using InsTK.Shared.Models.Tutorials

<EditForm Model="Model" OnValidSubmit="OnSaveRequested" FormName="tutorialAuthoringForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-4">
        <button type="submit" class="btn btn-outline-primary me-2">Save</button>

        <button type="button" class="btn btn-outline-dark me-2" @onclick="OnExportRequested">
            Export
        </button>

        <button type="button" class="btn btn-outline-secondary" @onclick="OnReturnToListRequested">
            Return to List
        </button>
    </div>

    <div class="mb-3">
        <label class="form-label">Title</label>
        <InputText class="form-control" Value="@Model.Title" ValueChanged="OnTutorialTitleChanged"
                   ValueExpression="() => Model.Title" />
    </div>

    <div class="mb-3">
        <label class="form-label">Summary</label>
        <InputTextArea class="form-control" @bind-Value="Model.Summary" />
    </div>

    <div class="mb-3">
        <label class="form-label">YouTube URL</label>
        <InputText class="form-control font-monospace" @bind-Value="Model.YouTubeUrl" />
        <div class="form-text">
            Exported to WordPress immediately after the summary.
        </div>
    </div>

    <TutorialMarkdownEditor Label="Tutorial Content Markdown" Value="@Model.ContentMarkdown"
                            ValueChanged="OnContentMarkdownChanged" MinHeight="520px"
                            Placeholder="Write the full tutorial here. Use markdown headings like ## Step 1 if you want step structure." />

    <hr />

    <div class="mt-3 pb-4">
        <button type="submit" class="btn btn-outline-primary me-2">Save</button>

        <button type="button" class="btn btn-outline-dark me-2" @onclick="OnExportRequested">
            Export
        </button>

        <button type="button" class="btn btn-outline-secondary" @onclick="OnReturnToListRequested">
            Return to List
        </button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public TutorialDefinition Model { get; set; } = null!;

    [Parameter, EditorRequired]
    public EventCallback<string> OnTutorialTitleChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string> OnContentMarkdownChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback OnSaveRequested { get; set; }

    [Parameter, EditorRequired]
    public EventCallback OnExportRequested { get; set; }

    [Parameter, EditorRequired]
    public EventCallback OnReturnToListRequested { get; set; }
}
