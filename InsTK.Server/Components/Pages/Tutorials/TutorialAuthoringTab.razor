@using InsTK.Shared.Models.Tutorials

<EditForm Model="Model" OnValidSubmit="HandleSaveAsync" FormName="tutorialAuthoringForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-4">
        <button type="submit" class="btn btn-outline-primary me-2">Save</button>

        <button type="button" class="btn btn-outline-dark me-2" @onclick="HandleExportAsync">
            Export
        </button>

        <button type="button" class="btn btn-outline-secondary" @onclick="OnReturnToListRequested">
            Return to List
        </button>
    </div>

    <div class="mb-3">
        <label class="form-label">Title</label>
        <InputText id="tutorial-title" class="form-control" Value="@Model.Title" ValueChanged="OnTutorialTitleChanged"
                   ValueExpression="() => Model.Title" />
    </div>

    <div class="mb-3">
        <label class="form-label">Summary</label>
        <InputTextArea class="form-control" @bind-Value="Model.Summary" />
    </div>

    <div class="mb-3">
        <label class="form-label">YouTube URL</label>
        <InputText class="form-control font-monospace" @bind-Value="Model.YouTubeUrl" />
        <div class="form-text">
            Exported to WordPress immediately after the summary.
        </div>
    </div>

    <TutorialHtmlEditor @ref="editor" Label="Tutorial Content" Value="@Model.ContentHtml"
                        MinHeight="520px" ValueExpression="() => Model.ContentHtml"
                        Placeholder="Write the full tutorial here using headings, lists, links, images, and tables as needed." />

    <hr />

    <div class="mt-3 pb-4">
        <button type="submit" class="btn btn-outline-primary me-2">Save</button>

        <button type="button" class="btn btn-outline-dark me-2" @onclick="HandleExportAsync">
            Export
        </button>

        <button type="button" class="btn btn-outline-secondary" @onclick="OnReturnToListRequested">
            Return to List
        </button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public TutorialDefinition Model { get; set; } = null!;

    [Parameter, EditorRequired]
    public EventCallback<string> OnTutorialTitleChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<string> OnContentHtmlChanged { get; set; }

    [Parameter, EditorRequired]
    public EventCallback OnSaveRequested { get; set; }

    [Parameter, EditorRequired]
    public EventCallback OnExportRequested { get; set; }

    [Parameter, EditorRequired]
    public EventCallback OnReturnToListRequested { get; set; }

    private TutorialHtmlEditor? editor;

    private async Task HandleSaveAsync()
    {
        await SyncEditorContentAsync();
        await OnSaveRequested.InvokeAsync();
    }

    private async Task HandleExportAsync()
    {
        await SyncEditorContentAsync();
        await OnExportRequested.InvokeAsync();
    }

    private async Task SyncEditorContentAsync()
    {
        if (editor is null)
        {
            return;
        }

        var contentHtml = await editor.GetContentHtmlAsync();
        await OnContentHtmlChanged.InvokeAsync(contentHtml);
    }
}
