@using System.Net

<div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Title</h5>
                <button type="button" class="btn-close" aria-label="Close" @onclick="OnCloseRequested"></button>
            </div>

            <div class="modal-body">
                @foreach (var exportSection in Sections)
                {
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0">@exportSection.Title</h6>
                            <a class="btn btn-sm btn-outline-dark"
                               href="@BuildDownloadHref(exportSection.Content, exportSection.ContentType)"
                               download="@exportSection.FileName">
                                Download
                            </a>
                        </div>
                        <textarea class="form-control font-monospace" style="min-height: @(exportSection.MinHeightPx)px;" readonly>@exportSection.Content</textarea>
                    </div>
                }
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="OnCloseRequested">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal-backdrop fade show"></div>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public IReadOnlyList<TutorialExportSection> Sections { get; set; } = [];

    [Parameter, EditorRequired]
    public EventCallback OnCloseRequested { get; set; }

    private static string BuildDownloadHref(string content, string contentType)
    {
        return $"data:{contentType};charset=utf-8,{WebUtility.UrlEncode(content)}";
    }
}
