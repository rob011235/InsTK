@page "/tutorials/edit"
@page "/tutorials/edit/{Id:guid}"
@rendermode InteractiveServer

@using InsTK.Server.Data
@using InsTK.Shared.Models.Tutorials
@using Microsoft.EntityFrameworkCore

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<h3>@(IsNew ? "Create Tutorial" : "Edit Tutorial")</h3>

@if (model == null)
{
    <p>Loading...</p>
}
else
{
    <EditForm Model="model" OnValidSubmit="Save" FormName="tutorialForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <button type="button" class="nav-link @(activeTab == "tutorial" ? "active" : "")"
                        @onclick='() => SetActiveTab("tutorial")'>
                    Tutorial
                </button>
            </li>

            <li class="nav-item">
                <button type="button" class="nav-link @(activeTab == "reference" ? "active" : "")"
                        @onclick='() => SetActiveTab("reference")'>
                    Git Reference
                </button>
            </li>

            <li class="nav-item">
                <button type="button" class="nav-link @(activeTab == "assignment" ? "active" : "")"
                        @onclick='() => SetActiveTab("assignment")'>
                    Brightspace Assignment
                </button>
            </li>
        </ul>

        @if (activeTab == "tutorial")
        {
            <div class="mb-3">
                <label class="form-label">Title</label>
                <InputText class="form-control" Value="@model.Title" ValueChanged="OnTutorialTitleChanged"
                           ValueExpression="() => model.Title" />
            </div>

            <div class="mb-3">
                <label class="form-label">Summary</label>
                <InputTextArea class="form-control" @bind-Value="model.Summary" />
            </div>

            <div class="mb-3">
                <label class="form-label">Technology</label>
                <InputText class="form-control" @bind-Value="model.Technology" />
            </div>

            <TutorialMarkdownEditor Label="Tutorial Content Markdown" Value="@model.ContentMarkdown"
                                    ValueChanged="OnContentMarkdownChanged" MinHeight="520px"
                                    Placeholder="Write the full tutorial here. Use markdown headings like ## Step 1 if you want step structure." />

        }
        @if (activeTab == "reference")
        {

            <div class="mb-3">
                <h4>Instructor Reference</h4>
                <p class="text-muted mb-0">
                    Identify the final repository evidence for the tutorial as a whole. This can represent the combined outcome
                    of multiple steps.
                </p>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Repository URL</label>
                    <InputText class="form-control font-monospace" @bind-Value="model.RepoUrl" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Branch Name</label>
                    <InputText class="form-control font-monospace" @bind-Value="model.BranchName" />
                </div>

                <div class="col-12">
                    <label class="form-label">Reference Subpath</label>
                    <InputText class="form-control font-monospace" @bind-Value="model.ReferenceSubPath" />
                    <div class="form-text">
                        Optional repo subdirectory that contains the final tutorial result.
                    </div>
                </div>

                <div class="col-12">
                    <label class="form-label">Reference File Names</label>
                    <InputTextArea class="form-control font-monospace" style="min-height: 120px;"
                                   @bind-Value="model.ReferenceFileNames" />
                    <div class="form-text">
                        List the repo files that demonstrate the final tutorial result. One file per line works well.
                    </div>
                </div>

                <div class="col-12">
                    <label class="form-label">Grading Hints</label>
                    <InputTextArea class="form-control" style="min-height: 120px;" @bind-Value="model.GradingHints" />
                </div>

                <div class="col-12">
                    <label class="form-label">Reference Code</label>
                    <InputTextArea class="form-control font-monospace" style="min-height: 260px;"
                                   @bind-Value="model.ReferenceCode" />
                    <div class="form-text">
                        Use this for the final reference implementation or combined expected result.
                    </div>
                </div>
            </div>

            <div class="alert alert-light border small mt-3 mb-0">
                Status: @(IsGradableTutorial() ? "Gradable tutorial" : "Instruction-only tutorial")
            </div>
        }
        @if (activeTab == "assignment")
        {

            <div class="mb-3">
                <h4>Brightspace Assignment Draft</h4>
                <p class="text-muted mb-0">
                    Draft the assignment shell that will be copied into Brightspace.
                </p>
            </div>

            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label">Assignment Title</label>
                    <InputText class="form-control" Value="@model.BrightspaceAssignmentTitle"
                               ValueChanged="OnBrightspaceAssignmentTitleChanged"
                               ValueExpression="() => model.BrightspaceAssignmentTitle" />
                    <div class="form-text">
                        Leave blank to use the tutorial title.
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Points</label>
                    <InputNumber class="form-control" @bind-Value="model.BrightspacePoints" />
                </div>

                <div class="col-12">
                    <label class="form-label">Assignment Instructions</label>
                    <InputTextArea class="form-control" style="min-height: 180px;"
                                   @bind-Value="model.BrightspaceAssignmentInstructions" />
                    <div class="form-text">
                        These are instructor-facing assignment directions for Brightspace.
                    </div>
                </div>

                <div class="col-12">
                    <label class="form-label">Submission Instructions</label>
                    <InputTextArea class="form-control" style="min-height: 120px;"
                                   @bind-Value="model.BrightspaceSubmissionInstructions" />
                    <div class="form-text">
                        Example: Submit your GitHub repository URL and branch name in the Brightspace comments.
                    </div>
                </div>
            </div>

        }
            <hr />

            <div class="mt-3">
                <button type="submit" class="btn btn-primary me-2">Save</button>

                @if (!IsNew)
                {
                    <button type="button" class="btn btn-outline-primary me-2" @onclick="Preview">
                        Preview
                    </button>

                    <button type="button" class="btn btn-outline-dark me-2" @onclick="Export">
                        Export
                    </button>
                }

                <button type="button" class="btn btn-secondary" @onclick="Cancel">
                    Cancel
                </button>
            </div>
    </EditForm>
}

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private TutorialDefinition? model;

    private bool IsNew => !Id.HasValue;
    private string activeTab = "tutorial";
    private bool assignmentTitleWasManuallyEdited;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        if (IsNew)
        {
            model = new TutorialDefinition
            {
                CreatedUtc = DateTime.UtcNow
            };
        }
        else
        {
            var tutorialId = Id.GetValueOrDefault();

            model = await db.Tutorials
                .FirstOrDefaultAsync(t => t.Id == tutorialId);

            if (model == null)
            {
                Nav.NavigateTo("/tutorials");
                return;
            }

            // Apply defaults for existing records
            if (string.IsNullOrWhiteSpace(model.BrightspaceSubmissionInstructions))
            {
                model.BrightspaceSubmissionInstructions =
                    TutorialDefinition.DefaultBrightspaceSubmissionInstructions;
            }

            if (string.IsNullOrWhiteSpace(model.BrightspaceAssignmentTitle))
            {
                model.BrightspaceAssignmentTitle =
                    $"Tutorial - {model.Title}".Trim();
            }

            if (string.IsNullOrWhiteSpace(model.BrightspaceAssignmentInstructions))
            {
                model.BrightspaceAssignmentInstructions =
                    TutorialDefinition.DefaultBrightspaceAssignmentInstructions;
            }
        }

        assignmentTitleWasManuallyEdited = !string.IsNullOrWhiteSpace(model.BrightspaceAssignmentTitle);

        if (!assignmentTitleWasManuallyEdited)
        {
            model.BrightspaceAssignmentTitle = BuildDefaultAssignmentTitle(model.Title);
        }

    }

    private static string? NormalizeOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private Task OnContentMarkdownChanged(string value)
    {
        if (model != null)
        {
            model.ContentMarkdown = value;
        }

        return Task.CompletedTask;
    }

    private async Task Save()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        if (model == null)
            return;

        model.Title = model.Title?.Trim() ?? string.Empty;
        model.Summary = NormalizeOptional(model.Summary);
        model.Technology = NormalizeOptional(model.Technology);
        model.ContentMarkdown = NormalizeOptional(model.ContentMarkdown);
        model.RepoUrl = NormalizeOptional(model.RepoUrl);
        model.BranchName = NormalizeOptional(model.BranchName);
        model.ReferenceSubPath = NormalizeOptional(model.ReferenceSubPath);
        model.ReferenceFileNames = NormalizeOptional(model.ReferenceFileNames);
        model.ReferenceCode = NormalizeOptional(model.ReferenceCode);
        model.GradingHints = NormalizeOptional(model.GradingHints);
        model.BrightspaceAssignmentTitle = string.IsNullOrWhiteSpace(model.BrightspaceAssignmentTitle)
            ? BuildDefaultAssignmentTitle(model.Title)
            : model.BrightspaceAssignmentTitle.Trim();
        model.BrightspaceAssignmentInstructions = NormalizeOptional(model.BrightspaceAssignmentInstructions);
        model.BrightspaceSubmissionInstructions = NormalizeOptional(model.BrightspaceSubmissionInstructions);

        if (model.BrightspacePoints <= 0)
        {
            model.BrightspacePoints = 100;
        }

        if (IsNew)
        {
            model.CreatedUtc = DateTime.UtcNow;
            db.Tutorials.Add(model);
        }
        else
        {
            if (!await db.Tutorials.AnyAsync(t => t.Id == model.Id))
            {
                Nav.NavigateTo("/tutorials");
                return;
            }

            var updatedUtc = DateTime.UtcNow;

            await db.Tutorials
                .Where(t => t.Id == model.Id)
                .ExecuteUpdateAsync(setters => setters
                    .SetProperty(t => t.Title, model.Title)
                    .SetProperty(t => t.Summary, model.Summary)
                    .SetProperty(t => t.Technology, model.Technology)
                    .SetProperty(t => t.ContentMarkdown, model.ContentMarkdown)
                    .SetProperty(t => t.RepoUrl, model.RepoUrl)
                    .SetProperty(t => t.BranchName, model.BranchName)
                    .SetProperty(t => t.ReferenceSubPath, model.ReferenceSubPath)
                    .SetProperty(t => t.ReferenceFileNames, model.ReferenceFileNames)
                    .SetProperty(t => t.ReferenceCode, model.ReferenceCode)
                    .SetProperty(t => t.GradingHints, model.GradingHints)
                    .SetProperty(t => t.UpdatedUtc, updatedUtc)
                    .SetProperty(t => t.BrightspaceAssignmentTitle, model.BrightspaceAssignmentTitle)
                    .SetProperty(t => t.BrightspaceAssignmentInstructions, model.BrightspaceAssignmentInstructions)
                    .SetProperty(t => t.BrightspacePoints, model.BrightspacePoints)
                    .SetProperty(t => t.BrightspaceSubmissionInstructions, model.BrightspaceSubmissionInstructions));
        }

        await db.SaveChangesAsync();

        Nav.NavigateTo("/tutorials");
    }

    private void Cancel()
    {
        Nav.NavigateTo("/tutorials");
    }

    private void Preview()
    {
        if (model == null)
            return;

        Nav.NavigateTo($"/tutorials/{model.Id}/preview");
    }

    private void Export()
    {
        if (model == null)
            return;

        Nav.NavigateTo($"/tutorials/{model.Id}/export");
    }

    private bool IsGradableTutorial()
    {
        return model != null && !string.IsNullOrWhiteSpace(model.ReferenceCode);
    }

    private void SetActiveTab(string tabName)
    {
        activeTab = tabName;
    }

    private Task OnTutorialTitleChanged(string value)
    {
        if (model == null)
        {
            return Task.CompletedTask;
        }

        model.Title = value;

        if (!assignmentTitleWasManuallyEdited)
        {
            model.BrightspaceAssignmentTitle = BuildDefaultAssignmentTitle(value);
        }

        return Task.CompletedTask;
    }

    private Task OnBrightspaceAssignmentTitleChanged(string value)
    {
        if (model == null)
        {
            return Task.CompletedTask;
        }

        model.BrightspaceAssignmentTitle = value;
        assignmentTitleWasManuallyEdited = !string.IsNullOrWhiteSpace(value);

        return Task.CompletedTask;
    }

    private static string BuildDefaultAssignmentTitle(string? tutorialTitle)
    {
        return string.IsNullOrWhiteSpace(tutorialTitle)
            ? "Tutorial"
            : $"Tutorial - {tutorialTitle.Trim()}";
    }
}
