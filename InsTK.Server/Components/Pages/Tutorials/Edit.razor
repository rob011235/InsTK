@page "/tutorials/edit"
@page "/tutorials/edit/{Id:guid}"
@rendermode InteractiveServer

@using InsTK.Server.Data
@using InsTK.Shared.Models.Tutorials
@using Microsoft.EntityFrameworkCore

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<h3>@(IsNew ? "Create Tutorial" : "Edit Tutorial")</h3>

@if (model == null)
{
    <p>Loading...</p>
}
else
{
    <EditForm Model="model" OnValidSubmit="Save" FormName="tutorialForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Title</label>
            <InputText class="form-control" @bind-Value="model.Title" />
        </div>

        <div class="mb-3">
            <label class="form-label">Summary</label>
            <InputTextArea class="form-control" @bind-Value="model.Summary" />
        </div>

        <div class="mb-3">
            <label class="form-label">Technology</label>
            <InputText class="form-control" @bind-Value="model.Technology" />
        </div>

        <TutorialMarkdownEditor Label="Introduction Markdown"
                                Value="@model.IntroMarkdown"
                                ValueChanged="OnIntroMarkdownChanged"
                                MinHeight="220px"
                                Placeholder="Add an introduction, setup notes, or learning goals."
                                EmptyPreviewMessage="Introduction preview will appear as you write markdown." />

        <hr />

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Steps</h4>
        </div>

        @if (!model.Steps.Any())
        {
            <p>No steps added yet.</p>
        }
        else
        {
            @foreach (var step in model.Steps.OrderBy(s => s.DisplayOrder).ToList())
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0">Step @step.DisplayOrder</h5>

                            <div>
                                <button type="button" class="btn btn-sm btn-outline-secondary me-2"
                                        @onclick="() => MoveStepUp(step)">
                                    Up
                                </button>

                                <button type="button" class="btn btn-sm btn-outline-secondary me-2"
                                        @onclick="() => MoveStepDown(step)">
                                    Down
                                </button>

                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveStep(step)">
                                    Remove
                                </button>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Title</label>
                            <InputText class="form-control" @bind-Value="step.Title" />
                        </div>

                        <TutorialMarkdownEditor Label="Instruction Markdown"
                                                Value="@step.InstructionMarkdown"
                                                ValueChanged="value => OnStepMarkdownChanged(step, value)"
                                                MinHeight="250px"
                                                Placeholder="Write the student-facing markdown for this step."
                                                EmptyPreviewMessage="Step preview will appear as you write markdown." />

                    </div>
                </div>
            }
        }

        <button type="button" class="btn btn-outline-primary" @onclick="AddStep">
            Add Step
        </button>

        <div class="mt-4">
            <TutorialMarkdownEditor Label="Conclusion Markdown"
                                    Value="@model.ConclusionMarkdown"
                                    ValueChanged="OnConclusionMarkdownChanged"
                                    MinHeight="220px"
                                    Placeholder="Add wrap-up notes, next steps, or recap content."
                                    EmptyPreviewMessage="Conclusion preview will appear as you write markdown." />
        </div>

        <hr />

        <div class="mb-3">
            <h4>Instructor Reference</h4>
            <p class="text-muted mb-0">
                Identify the final repository evidence for the tutorial as a whole. This can represent the combined outcome of multiple steps.
            </p>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Repository URL</label>
                <InputText class="form-control font-monospace" @bind-Value="model.RepoUrl" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Branch Name</label>
                <InputText class="form-control font-monospace" @bind-Value="model.BranchName" />
            </div>

            <div class="col-12">
                <label class="form-label">Reference Subpath</label>
                <InputText class="form-control font-monospace" @bind-Value="model.ReferenceSubPath" />
                <div class="form-text">
                    Optional repo subdirectory that contains the final tutorial result.
                </div>
            </div>

            <div class="col-12">
                <label class="form-label">Reference File Names</label>
                <InputTextArea class="form-control font-monospace" style="min-height: 120px;"
                               @bind-Value="model.ReferenceFileNames" />
                <div class="form-text">
                    List the repo files that demonstrate the final tutorial result. One file per line works well.
                </div>
            </div>

            <div class="col-12">
                <label class="form-label">Grading Hints</label>
                <InputTextArea class="form-control" style="min-height: 120px;"
                               @bind-Value="model.GradingHints" />
            </div>

            <div class="col-12">
                <label class="form-label">Reference Code</label>
                <InputTextArea class="form-control font-monospace" style="min-height: 260px;"
                               @bind-Value="model.ReferenceCode" />
                <div class="form-text">
                    Use this for the final reference implementation or combined expected result.
                </div>
            </div>
        </div>

        <div class="alert alert-light border small mt-3 mb-0">
            Status: @(IsGradableTutorial() ? "Gradable tutorial" : "Instruction-only tutorial")
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary me-2">Save</button>

            @if (!IsNew)
            {
                <button type="button" class="btn btn-outline-primary me-2" @onclick="Preview">
                    Preview
                </button>

                <button type="button" class="btn btn-outline-dark me-2" @onclick="Export">
                    Export
                </button>
            }

            <button type="button" class="btn btn-secondary" @onclick="Cancel">
                Cancel
            </button>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private TutorialDefinition? model;

    private bool IsNew => !Id.HasValue;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        if (IsNew)
        {
            model = new TutorialDefinition
            {
                CreatedUtc = DateTime.UtcNow
            };
        }
        else
        {
            var tutorialId = Id.GetValueOrDefault();

            model = await db.Tutorials
                .Include(t => t.Steps)
                .FirstOrDefaultAsync(t => t.Id == tutorialId);

            if (model == null)
            {
                Nav.NavigateTo("/tutorials");
                return;
            }
        }

        NormalizeStepOrder();
    }

    private void AddStep()
    {
        if (model == null)
            return;

        model.Steps.Add(new TutorialStep
        {
            DisplayOrder = model.Steps.Count + 1,
            Title = string.Empty,
            InstructionMarkdown = string.Empty
        });

        NormalizeStepOrder();
    }

    private void RemoveStep(TutorialStep step)
    {
        if (model == null)
            return;

        model.Steps.Remove(step);
        NormalizeStepOrder();
    }

    private void MoveStepUp(TutorialStep step)
    {
        if (model == null)
            return;

        var ordered = model.Steps.OrderBy(s => s.DisplayOrder).ToList();
        var index = ordered.IndexOf(step);

        if (index <= 0)
            return;

        (ordered[index - 1], ordered[index]) = (ordered[index], ordered[index - 1]);

        model.Steps = ordered;
        NormalizeStepOrder();
    }

    private void MoveStepDown(TutorialStep step)
    {
        if (model == null)
            return;

        var ordered = model.Steps.OrderBy(s => s.DisplayOrder).ToList();
        var index = ordered.IndexOf(step);

        if (index < 0 || index >= ordered.Count - 1)
            return;

        (ordered[index], ordered[index + 1]) = (ordered[index + 1], ordered[index]);

        model.Steps = ordered;
        NormalizeStepOrder();
    }

    private void NormalizeStepOrder()
    {
        if (model == null)
            return;

        var order = 1;

        foreach (var step in model.Steps.OrderBy(s => s.DisplayOrder))
        {
            step.DisplayOrder = order++;
        }
    }

    private static string? NormalizeOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private Task OnIntroMarkdownChanged(string value)
    {
        if (model != null)
        {
            model.IntroMarkdown = value;
        }

        return Task.CompletedTask;
    }

    private Task OnConclusionMarkdownChanged(string value)
    {
        if (model != null)
        {
            model.ConclusionMarkdown = value;
        }

        return Task.CompletedTask;
    }

    private Task OnStepMarkdownChanged(TutorialStep step, string value)
    {
        step.InstructionMarkdown = value;
        return Task.CompletedTask;
    }

    private async Task Save()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        if (model == null)
            return;

        NormalizeStepOrder();

        model.Title = model.Title?.Trim() ?? string.Empty;
        model.Summary = NormalizeOptional(model.Summary);
        model.Technology = NormalizeOptional(model.Technology);
        model.IntroMarkdown = NormalizeOptional(model.IntroMarkdown);
        model.ConclusionMarkdown = NormalizeOptional(model.ConclusionMarkdown);
        model.RepoUrl = NormalizeOptional(model.RepoUrl);
        model.BranchName = NormalizeOptional(model.BranchName);
        model.ReferenceSubPath = NormalizeOptional(model.ReferenceSubPath);
        model.ReferenceFileNames = NormalizeOptional(model.ReferenceFileNames);
        model.ReferenceCode = NormalizeOptional(model.ReferenceCode);
        model.GradingHints = NormalizeOptional(model.GradingHints);

        foreach (var step in model.Steps)
        {
            step.Title = step.Title?.Trim() ?? string.Empty;
            step.InstructionMarkdown = step.InstructionMarkdown?.Trim() ?? string.Empty;
        }

        if (IsNew)
        {
            model.CreatedUtc = DateTime.UtcNow;
            db.Tutorials.Add(model);
        }
        else
        {
            if (!await db.Tutorials.AnyAsync(t => t.Id == model.Id))
            {
                Nav.NavigateTo("/tutorials");
                return;
            }

            var updatedUtc = DateTime.UtcNow;

            await db.Tutorials
                .Where(t => t.Id == model.Id)
                .ExecuteUpdateAsync(setters => setters
                    .SetProperty(t => t.Title, model.Title)
                    .SetProperty(t => t.Summary, model.Summary)
                    .SetProperty(t => t.Technology, model.Technology)
                    .SetProperty(t => t.IntroMarkdown, model.IntroMarkdown)
                    .SetProperty(t => t.ConclusionMarkdown, model.ConclusionMarkdown)
                    .SetProperty(t => t.RepoUrl, model.RepoUrl)
                    .SetProperty(t => t.BranchName, model.BranchName)
                    .SetProperty(t => t.ReferenceSubPath, model.ReferenceSubPath)
                    .SetProperty(t => t.ReferenceFileNames, model.ReferenceFileNames)
                    .SetProperty(t => t.ReferenceCode, model.ReferenceCode)
                    .SetProperty(t => t.GradingHints, model.GradingHints)
                    .SetProperty(t => t.UpdatedUtc, updatedUtc));

            await db.TutorialSteps
                .Where(s => s.TutorialDefinitionId == model.Id)
                .ExecuteDeleteAsync();

            var replacementSteps = model.Steps
                .OrderBy(s => s.DisplayOrder)
                .Select(step => new TutorialStep
                {
                    TutorialDefinitionId = model.Id,
                    DisplayOrder = step.DisplayOrder,
                    Title = step.Title,
                    InstructionMarkdown = step.InstructionMarkdown
                })
                .ToList();

            db.TutorialSteps.AddRange(replacementSteps);
        }

        await db.SaveChangesAsync();

        Nav.NavigateTo("/tutorials");
    }

    private void Cancel()
    {
        Nav.NavigateTo("/tutorials");
    }

    private void Preview()
    {
        if (model == null)
            return;

        Nav.NavigateTo($"/tutorials/{model.Id}/preview");
    }

    private void Export()
    {
        if (model == null)
            return;

        Nav.NavigateTo($"/tutorials/{model.Id}/export");
    }

    private bool IsGradableTutorial()
    {
        return model != null && !string.IsNullOrWhiteSpace(model.ReferenceCode);
    }
}
