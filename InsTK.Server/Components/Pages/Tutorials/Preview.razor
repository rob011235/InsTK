@page "/tutorials/{Id:guid}/preview"
@rendermode InteractiveServer

@using InsTK.Server.Data
@using InsTK.Shared.Models.Tutorials
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Tutorial Preview</PageTitle>

@if (tutorial == null)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">@tutorial.Title</h3>
            @if (!string.IsNullOrWhiteSpace(tutorial.Technology))
            {
                <p class="text-muted mb-0">@tutorial.Technology</p>
            }
        </div>

        <div>
            <button type="button" class="btn btn-outline-secondary me-2" @onclick="BackToEdit">Back to Edit</button>
            <button type="button" class="btn btn-outline-dark" @onclick="OpenExport">Export</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(tutorial.Summary))
    {
        <div class="mb-4">
            <p class="lead mb-0">@tutorial.Summary</p>
        </div>
    }

    @if (!tutorial.Steps.Any())
    {
        <p>No steps have been added yet.</p>
    }
    else
    {
        <div class="vstack gap-4">
            @foreach (var step in tutorial.Steps.OrderBy(s => s.DisplayOrder))
            {
                <section class="card">
                    <div class="card-body">
                        <p class="text-muted text-uppercase small mb-2">Step @step.DisplayOrder</p>
                        <h4>@step.Title</h4>
                        <div>@((MarkupString)TutorialContentFormatter.RenderMarkdown(step.InstructionMarkdown))</div>
                    </div>
                </section>
            }
        </div>
    }
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private TutorialDefinition? tutorial;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        tutorial = await db.Tutorials
            .AsNoTracking()
            .Include(t => t.Steps)
            .FirstOrDefaultAsync(t => t.Id == Id);

        if (tutorial == null)
        {
            Nav.NavigateTo("/tutorials");
        }
    }

    private void BackToEdit()
    {
        Nav.NavigateTo($"/tutorials/edit/{Id}");
    }

    private void OpenExport()
    {
        Nav.NavigateTo($"/tutorials/{Id}/export");
    }
}
