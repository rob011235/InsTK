@page "/tutorials/{Id:guid}/preview"
@rendermode InteractiveServer

@using InsTK.Server.Data
@using InsTK.Shared.Models.Tutorials
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Tutorial Preview</PageTitle>

@if (tutorial == null)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">@tutorial.Title</h3>
            <p class="text-muted mb-0">Rendered from the same HTML that the WordPress export generates.</p>
        </div>

        <div>
            <button type="button" class="btn btn-outline-secondary me-2" @onclick="BackToEdit">Back to Edit</button>
            <button type="button" class="btn btn-outline-dark" @onclick="OpenExport">Export</button>
        </div>
    </div>

    <section class="wordpress-preview-shell">
        <div class="wordpress-preview-surface">
            <article class="wordpress-preview-content">
                @((MarkupString)wordpressHtml)
            </article>
        </div>
    </section>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private TutorialDefinition? tutorial;
    private string wordpressHtml = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        tutorial = await db.Tutorials
            .AsNoTracking()
            .FirstOrDefaultAsync(t => t.Id == Id);

        if (tutorial == null)
        {
            Nav.NavigateTo("/tutorials");
            return;
        }

        wordpressHtml = TutorialContentFormatter.BuildWordPressHtml(tutorial);
    }

    private void BackToEdit()
    {
        Nav.NavigateTo($"/tutorials/edit/{Id}");
    }

    private void OpenExport()
    {
        Nav.NavigateTo($"/tutorials/{Id}/export");
    }
}
