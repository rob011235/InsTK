@page "/admin/sme-questionnaires"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using Common.Interfaces
@using Common.Models.SmeQuestionnaire
@inject ISmeQuestionnaireDataService SmeQuestionnaireDataService

<PageTitle>Manage Questionnaires</PageTitle>

<h1>Manage SME Questionnaires</h1>

<p>
    <a class="btn btn-primary" href="/admin/sme-questionnaires/create">Create New Questionnaire</a>
</p>

@if (isLoading)
{
    <p>Loading questionnaires...</p>
}
else if (questionnaires.Count == 0)
{
    <p>No questionnaires found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Status</th>
                <th>Created</th>
                <th>Final Question</th>
            </tr>
        </thead>
        <tbody>
            @foreach (SmeQuestionnaire questionnaire in questionnaires)
            {
                <tr>
                    <td>@questionnaire.Title</td>
                    <td>@(questionnaire.IsActive ? "Active" : "Inactive")</td>
                    <td>@questionnaire.CreatedOn.ToLocalTime().ToString("g")</td>
                    <td>@(string.IsNullOrWhiteSpace(questionnaire.FinalOpenEndedPrompt) ? "None" : "Configured")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<SmeQuestionnaire> questionnaires = new List<SmeQuestionnaire>();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        questionnaires = await SmeQuestionnaireDataService.GetAllQuestionnairesAsync();
        isLoading = false;
    }
}
