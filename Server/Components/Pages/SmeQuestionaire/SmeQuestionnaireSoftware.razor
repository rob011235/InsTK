@page "/sme-questionnaire/{Token}/software"
@rendermode InteractiveServer
@attribute [AllowAnonymous]
@using Common.Interfaces
@using Common.Models.SmeQuestionnaire
@inject ISmeQuestionnaireDataService SmeQuestionnaireDataService
@inject NavigationManager Navigation

<PageTitle>SME Questionnaire Software</PageTitle>

<h1>SME Questionnaire</h1>
<p><strong>Step 3 of 5:</strong> Software</p>

@if (isLoading)
{
    <p>Loading software...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(saveMessage))
    {
        <p class="text-success">@saveMessage</p>
    }

    @foreach (SoftwareRow row in software)
    {
        <div class="border rounded p-3 mb-3" @key="row.RowId">
            <div class="input-group mb-3">
                <span class="input-group-text" id="@($"softwareNameLabel-{row.RowId}")">Software</span>
                <InputText
                    id="@($"softwareName-{row.RowId}")"
                    class="form-control"
                    aria-describedby="@($"softwareNameLabel-{row.RowId}")"
                    aria-label="Software name"
                    @bind-Value="row.Name" />
            </div>

            <div class="input-group mb-3">
                <span class="input-group-text" id="@($"softwareDescriptionLabel-{row.RowId}")">Description</span>
                <InputTextArea
                    id="@($"softwareDescription-{row.RowId}")"
                    class="form-control"
                    aria-describedby="@($"softwareDescriptionLabel-{row.RowId}")"
                    aria-label="Software description"
                    @bind-Value="row.Description" />
            </div>

            <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveSoftware(row)" disabled="@(software.Count == 1)">
                Remove Software
            </button>
        </div>
    }

    <div class="mb-3">
        <button type="button" class="btn btn-outline-secondary" @onclick="AddSoftware">Add Software</button>
    </div>

    <div class="d-flex gap-2 mb-3">
        <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">
            Back
        </button>
        <button type="button" class="btn btn-outline-primary" @onclick="SaveDraftAsync">
            Save Draft
        </button>
        <button type="button" class="btn btn-primary" @onclick="SaveAndNextAsync">
            Next
        </button>
    </div>
}

<p>
    <a href="/sme-questionnaire/privacy">How we use your data (Privacy Notice)</a>
</p>

@code {
    [Parameter]
    public string Token { get; set; } = string.Empty;

    private Guid responseId;
    private bool isLoading = true;
    private string? errorMessage;
    private string? saveMessage;
    private List<SoftwareRow> software = new List<SoftwareRow>();

    protected override async Task OnInitializedAsync()
    {
        if (!Guid.TryParse(Token, out responseId))
        {
            errorMessage = "Invalid questionnaire link.";
            isLoading = false;
            return;
        }

        List<SmeSoftware> existingSoftware = await SmeQuestionnaireDataService.GetSoftwareByResponseIdAsync(responseId);
        software = existingSoftware
            .Select(x => new SoftwareRow
            {
                Name = x.Name,
                Description = x.Notes,
            })
            .ToList();

        if (software.Count == 0)
        {
            software.Add(new SoftwareRow());
        }

        isLoading = false;
    }

    private void AddSoftware()
    {
        software.Add(new SoftwareRow());
    }

    private void RemoveSoftware(SoftwareRow row)
    {
        if (software.Count <= 1)
        {
            return;
        }

        software.Remove(row);

        if (software.Count == 0)
        {
            software.Add(new SoftwareRow());
        }
    }

    private async Task SaveDraftAsync()
    {
        bool success = await SaveSoftwareAsync();
        saveMessage = success ? "Draft saved." : "Unable to save software.";
    }

    private async Task SaveAndNextAsync()
    {
        bool success = await SaveSoftwareAsync();
        if (!success)
        {
            saveMessage = "Unable to save software.";
            return;
        }

        Navigation.NavigateTo($"/sme-questionnaire/{Token}/skills");
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"/sme-questionnaire/{Token}/equipment");
    }

    private async Task<bool> SaveSoftwareAsync()
    {
        List<SmeSoftware> rowsToSave = software
            .Where(x => !string.IsNullOrWhiteSpace(x.Name))
            .Select(x => new SmeSoftware
            {
                Name = x.Name.Trim(),
                Category = SoftwareCategory.Other,
                Frequency = UsageFrequency.Weekly,
                RequiredForJob = false,
                Notes = string.IsNullOrWhiteSpace(x.Description) ? null : x.Description.Trim(),
            })
            .ToList();

        return await SmeQuestionnaireDataService.SaveSoftwareByResponseIdAsync(responseId, rowsToSave);
    }

    private sealed class SoftwareRow
    {
        public Guid RowId { get; } = Guid.NewGuid();

        public string Name { get; set; } = string.Empty;

        public string? Description { get; set; }
    }
}
