@page "/sme-questionnaire/{Token}/facility-tour"
@rendermode InteractiveServer
@attribute [AllowAnonymous]
@using Common.Interfaces
@using Common.Models.SmeQuestionnaire
@inject ISmeQuestionnaireDataService SmeQuestionnaireDataService
@inject NavigationManager Navigation

<PageTitle>SME Questionnaire Facility Tour</PageTitle>

<h1>SME Questionnaire</h1>
<p><strong>Step 6 of 6:</strong> Facility Tour</p>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(saveMessage))
    {
        <p class="text-success">@saveMessage</p>
    }

    <p>Would you be willing to offer a tour of your facility?</p>

    <InputRadioGroup @bind-Value="model.IsWillingToOfferTour" Name="facilityTourWilling">
        <div class="form-check">
            <InputRadio class="form-check-input" id="facilityTourYes" Value="true" />
            <label class="form-check-label" for="facilityTourYes">Yes</label>
        </div>
        <div class="form-check">
            <InputRadio class="form-check-input" id="facilityTourNo" Value="false" />
            <label class="form-check-label" for="facilityTourNo">No</label>
        </div>
    </InputRadioGroup>

    <div class="input-group my-3">
        <span class="input-group-text" id="facilityTourDetailsLabel">Details</span>
        <InputTextArea
            id="facilityTourDetails"
            class="form-control"
            aria-label="Facility tour details"
            aria-describedby="facilityTourDetailsLabel"
            @bind-Value="model.Details" />
    </div>

    @if (model.IsWillingToOfferTour == true)
    {
        <h2 class="h5 mt-4">Availability Dates and Times</h2>
        <p class="text-muted">Add one or more date/time options when you could offer a tour.</p>

        @foreach (AvailabilityRow row in availabilityRows)
        {
            <div class="border rounded p-3 mb-3" @key="row.RowId">
                <div class="input-group mb-2">
                    <span class="input-group-text">Date</span>
                    <input
                        type="date"
                        class="form-control"
                        value="@row.Date"
                        @onchange="(args) => row.Date = args.Value?.ToString() ?? string.Empty" />
                </div>

                <div class="input-group mb-2">
                    <span class="input-group-text">Start</span>
                    <input
                        type="time"
                        class="form-control"
                        value="@row.StartTime"
                        @onchange="(args) => row.StartTime = args.Value?.ToString() ?? string.Empty" />
                    <span class="input-group-text">End</span>
                    <input
                        type="time"
                        class="form-control"
                        value="@row.EndTime"
                        @onchange="(args) => row.EndTime = args.Value?.ToString() ?? string.Empty" />
                </div>

                <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveAvailability(row)" disabled="@(availabilityRows.Count == 1)">
                    Remove Availability
                </button>
            </div>
        }

        <div class="mb-3">
            <button type="button" class="btn btn-outline-secondary" @onclick="AddAvailability">Add Availability</button>
        </div>
    }

    <div class="d-flex gap-2 mb-3">
        <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">
            Back
        </button>
        <button type="button" class="btn btn-outline-primary" @onclick="SaveDraftAsync">
            Save Draft
        </button>
        <button type="button" class="btn btn-primary" @onclick="SaveAndSubmitAsync">
            Submit
        </button>
    </div>
}

<p>
    <a href="/sme-questionnaire/privacy">How we use your data (Privacy Notice)</a>
</p>

@code {
    [Parameter]
    public string Token { get; set; } = string.Empty;

    private readonly SmeFacilityTourPreference model = new SmeFacilityTourPreference();
    private Guid responseId;
    private bool isLoading = true;
    private string? errorMessage;
    private string? saveMessage;
    private List<AvailabilityRow> availabilityRows = new List<AvailabilityRow>();

    protected override async Task OnInitializedAsync()
    {
        if (!Guid.TryParse(Token, out responseId))
        {
            errorMessage = "Invalid questionnaire link.";
            isLoading = false;
            return;
        }

        SmeFacilityTourPreference? existing = await SmeQuestionnaireDataService.GetFacilityTourPreferenceByResponseIdAsync(responseId);
        if (existing is null)
        {
            errorMessage = "Unable to load facility tour preference.";
            isLoading = false;
            return;
        }

        model.IsWillingToOfferTour = existing.IsWillingToOfferTour;
        model.Details = existing.Details;
        availabilityRows = existing.Availabilities
            .Select(x => new AvailabilityRow
            {
                Date = x.Date ?? string.Empty,
                StartTime = x.StartTime ?? string.Empty,
                EndTime = x.EndTime ?? string.Empty,
            })
            .ToList();

        if (availabilityRows.Count == 0)
        {
            availabilityRows.Add(new AvailabilityRow());
        }

        isLoading = false;
    }

    private async Task SaveDraftAsync()
    {
        bool success = await SaveAsync();
        saveMessage = success ? "Draft saved." : "Unable to save.";
    }

    private async Task SaveAndSubmitAsync()
    {
        bool success = await SaveAsync();
        if (!success)
        {
            saveMessage = "Unable to save.";
            return;
        }

        bool submitted = await SmeQuestionnaireDataService.MarkResponseSubmittedAsync(responseId);
        if (!submitted)
        {
            saveMessage = "Unable to submit survey.";
            return;
        }

        Navigation.NavigateTo($"/sme-questionnaire/{Token}/submitted");
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"/sme-questionnaire/{Token}/final-question");
    }

    private void AddAvailability()
    {
        availabilityRows.Add(new AvailabilityRow());
    }

    private void RemoveAvailability(AvailabilityRow row)
    {
        if (availabilityRows.Count <= 1)
        {
            return;
        }

        availabilityRows.Remove(row);
    }

    private async Task<bool> SaveAsync()
    {
        List<SmeFacilityTourAvailability> availabilitiesToSave = model.IsWillingToOfferTour == true
            ? availabilityRows
                .Select(x => new SmeFacilityTourAvailability
                {
                    Date = string.IsNullOrWhiteSpace(x.Date) ? null : x.Date.Trim(),
                    StartTime = string.IsNullOrWhiteSpace(x.StartTime) ? null : x.StartTime.Trim(),
                    EndTime = string.IsNullOrWhiteSpace(x.EndTime) ? null : x.EndTime.Trim(),
                })
                .ToList()
            : new List<SmeFacilityTourAvailability>();

        SmeFacilityTourPreference toSave = new SmeFacilityTourPreference
        {
            IsWillingToOfferTour = model.IsWillingToOfferTour,
            Details = string.IsNullOrWhiteSpace(model.Details) ? null : model.Details.Trim(),
            Availabilities = availabilitiesToSave,
        };

        return await SmeQuestionnaireDataService.SaveFacilityTourPreferenceByResponseIdAsync(responseId, toSave);
    }

    private sealed class AvailabilityRow
    {
        public Guid RowId { get; } = Guid.NewGuid();

        public string Date { get; set; } = string.Empty;

        public string StartTime { get; set; } = string.Empty;

        public string EndTime { get; set; } = string.Empty;
    }
}
