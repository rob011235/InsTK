@page "/admin/curriculums/create"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using System.ComponentModel.DataAnnotations
@using Common.Interfaces
@using Common.Models.SmeQuestionnaire
@inject ISmeQuestionnaireDataService SmeQuestionnaireDataService
@inject NavigationManager Navigation

<PageTitle>Create Curriculum</PageTitle>

<h1>Create Curriculum</h1>

<EditForm Model="model" OnValidSubmit="CreateAsync" FormName="CreateCurriculumForm">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="titleInput" class="form-label">Title</label>
        <InputText id="titleInput" class="form-control" @bind-Value="model.Title" />
    </div>

    <div class="mb-3">
        <label for="descriptionInput" class="form-label">Description</label>
        <InputTextArea id="descriptionInput" class="form-control" @bind-Value="model.Description" />
    </div>

    <div class="mb-3">
        <label for="targetStartInput" class="form-label">Target Start Date</label>
        <InputDate id="targetStartInput" class="form-control" @bind-Value="model.TargetStartDate" />
    </div>

    <div class="mb-3">
        <label for="targetEndInput" class="form-label">Target End Date</label>
        <InputDate id="targetEndInput" class="form-control" @bind-Value="model.TargetEndDate" />
    </div>

    <button type="submit" class="btn btn-primary">Create Curriculum</button>
    <a class="btn btn-link" href="/admin/curriculums">Cancel</a>
</EditForm>

@code {
    private readonly CreateCurriculumModel model = new CreateCurriculumModel();

    private async Task CreateAsync()
    {
        Curriculum curriculum = new Curriculum
        {
            Title = model.Title.Trim(),
            Description = string.IsNullOrWhiteSpace(model.Description) ? null : model.Description.Trim(),
            TargetStartDate = model.TargetStartDate.HasValue
                ? new DateTimeOffset(model.TargetStartDate.Value.Date, TimeSpan.Zero)
                : null,
            TargetEndDate = model.TargetEndDate.HasValue
                ? new DateTimeOffset(model.TargetEndDate.Value.Date, TimeSpan.Zero)
                : null,
        };

        await SmeQuestionnaireDataService.CreateCurriculumAsync(curriculum);
        Navigation.NavigateTo("/admin/curriculums");
    }

    private sealed class CreateCurriculumModel
    {
        [Required]
        [MaxLength(200)]
        public string Title { get; set; } = string.Empty;

        [MaxLength(2000)]
        public string? Description { get; set; }

        public DateTime? TargetStartDate { get; set; }

        public DateTime? TargetEndDate { get; set; }
    }
}
