@page "/admin/sme-surveys"
@page "/admin/sme-questionnaire-invites/list"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using Common.Interfaces
@using Common.Models.SmeQuestionnaire
@inject ISmeQuestionnaireDataService SmeQuestionnaireDataService

<PageTitle>SME Surveys</PageTitle>

<h1>SME Surveys</h1>

<p>
    <a class="btn btn-primary" href="/admin/sme-questionnaire-invites">Generate New Survey Invite</a>
</p>

@if (isLoading)
{
    <p>Loading surveys...</p>
}
else if (invites.Count == 0)
{
    <p>No surveys found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>SME</th>
                <th>Email</th>
                <th>Questionnaire</th>
                <th>Status</th>
                <th>Started</th>
                <th>Privacy Ack</th>
                <th>Submitted</th>
                <th>Link</th>
                <th>PDF</th>
            </tr>
        </thead>
        <tbody>
            @foreach (SmeInviteListItem invite in invites)
            {
                <tr>
                    <td>@invite.SmeFullName</td>
                    <td>@(string.IsNullOrWhiteSpace(invite.SmeEmail) ? "-" : invite.SmeEmail)</td>
                    <td>@invite.QuestionnaireTitle</td>
                    <td>@invite.Status</td>
                    <td>@invite.StartedOn.ToLocalTime().ToString("g")</td>
                    <td>@FormatDateTime(invite.PrivacyAcknowledgedOn)</td>
                    <td>@FormatDateTime(invite.SubmittedOn)</td>
                    <td><a href="@($"/sme-questionnaire/{invite.ResponseId}")" target="_blank">Open</a></td>
                    <td><a href="@($"/api/sme-surveys/{invite.ResponseId}/pdf")" target="_blank">Download</a></td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<SmeInviteListItem> invites = new List<SmeInviteListItem>();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        invites = await SmeQuestionnaireDataService.GetInviteListAsync();
        isLoading = false;
    }

    private static string FormatDateTime(DateTimeOffset? value)
    {
        return value.HasValue ? value.Value.ToLocalTime().ToString("g") : "-";
    }
}
