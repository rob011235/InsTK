@page "/sme-questionnaire/{Token}/final-question"
@rendermode InteractiveServer
@attribute [AllowAnonymous]
@using Common.Interfaces
@using Common.Models.SmeQuestionnaire
@inject ISmeQuestionnaireDataService SmeQuestionnaireDataService
@inject NavigationManager Navigation

<PageTitle>SME Questionnaire Final Question</PageTitle>

<h1>SME Questionnaire</h1>
<p><strong>Step 5 of 6:</strong> Final Question</p>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(saveMessage))
    {
        <p class="text-success">@saveMessage</p>
    }

    <p>@promptText</p>

    <div class="input-group my-3">
        <span class="input-group-text" id="finalQuestionAnswerLabel">Answer</span>
        <InputTextArea
            id="finalQuestionAnswer"
            class="form-control"
            style="min-height: 60vh;"
            aria-label="Final answer"
            aria-describedby="finalQuestionAnswerLabel"
            @bind-Value="answer" />
    </div>

    @if (!string.IsNullOrWhiteSpace(validationMessage))
    {
        <p class="text-danger">@validationMessage</p>
    }

    <div class="d-flex gap-2 mb-3">
        <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">
            Back
        </button>
        <button type="button" class="btn btn-outline-primary" @onclick="SaveDraftAsync">
            Save Draft
        </button>
        <button type="button" class="btn btn-primary" @onclick="SaveAndNextAsync">
            Next
        </button>
    </div>
}

<p>
    <a href="/sme-questionnaire/privacy">How we use your data (Privacy Notice)</a>
</p>

@code {
    [Parameter]
    public string Token { get; set; } = string.Empty;

    private Guid responseId;
    private bool isLoading = true;
    private string? errorMessage;
    private string? saveMessage;
    private string? validationMessage;
    private string? answer;
    private string promptText = "Is there anything else you'd like to share?";
    private bool isAnswerRequired;

    protected override async Task OnInitializedAsync()
    {
        if (!Guid.TryParse(Token, out responseId))
        {
            errorMessage = "Invalid questionnaire link.";
            isLoading = false;
            return;
        }

        SmeQuestionnaireResponse? response = await SmeQuestionnaireDataService.GetResponseByIdAsync(responseId);
        if (response is null)
        {
            errorMessage = "Questionnaire response not found.";
            isLoading = false;
            return;
        }

        SmeQuestionnaire? questionnaire = await SmeQuestionnaireDataService.GetQuestionnaireByResponseIdAsync(responseId);
        if (questionnaire is not null)
        {
            if (!string.IsNullOrWhiteSpace(questionnaire.FinalOpenEndedPrompt))
            {
                promptText = questionnaire.FinalOpenEndedPrompt.Trim();
            }

            isAnswerRequired = questionnaire.IsFinalOpenEndedRequired;
        }

        answer = response.FinalOpenEndedAnswer;
        isLoading = false;
    }

    private async Task SaveDraftAsync()
    {
        validationMessage = null;
        bool success = await SmeQuestionnaireDataService.SaveFinalOpenEndedAnswerByResponseIdAsync(responseId, answer);
        saveMessage = success ? "Draft saved." : "Unable to save.";
    }

    private async Task SaveAndNextAsync()
    {
        validationMessage = null;
        if (isAnswerRequired && string.IsNullOrWhiteSpace(answer))
        {
            validationMessage = "This response is required before submission.";
            return;
        }

        bool saved = await SmeQuestionnaireDataService.SaveFinalOpenEndedAnswerByResponseIdAsync(responseId, answer);
        if (!saved)
        {
            saveMessage = "Unable to save.";
            return;
        }

        Navigation.NavigateTo($"/sme-questionnaire/{Token}/facility-tour");
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"/sme-questionnaire/{Token}/facility-tour");
    }
}
