@page "/admin/smes/create"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using Common.Models.SmeQuestionnaire
@inject NavigationManager Navigation

<PageTitle>Create SME</PageTitle>

<h1>Create Subject Matter Expert</h1>

<SmeCreateForm FormIdPrefix="create-sme-page" OnCreated="HandleCreatedAsync" SubmitButtonText="Create SME" />
<a class="btn btn-link mt-3" href="/admin/sme-surveys">Cancel</a>

@code {
    private Task HandleCreatedAsync(SubjectMatterExpert _)
    {
        Navigation.NavigateTo("/admin/sme-surveys");
        return Task.CompletedTask;
    }
}
