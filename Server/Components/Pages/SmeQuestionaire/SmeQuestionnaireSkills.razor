@page "/sme-questionnaire/{Token}/skills"
@rendermode InteractiveServer
@attribute [AllowAnonymous]
@using Common.Interfaces
@using Common.Models.SmeQuestionnaire
@inject ISmeQuestionnaireDataService SmeQuestionnaireDataService
@inject NavigationManager Navigation

<PageTitle>SME Questionnaire Skills</PageTitle>

<h1>SME Questionnaire</h1>
<p><strong>Step 4 of 5:</strong> Skills</p>

@if (isLoading)
{
    <p>Loading skills...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(saveMessage))
    {
        <p class="text-success">@saveMessage</p>
    }

    @foreach (SkillRow row in skills)
    {
        <div class="border rounded p-3 mb-3" @key="row.RowId">
            <div class="input-group mb-3">
                <span class="input-group-text" id="@($"skillNameLabel-{row.RowId}")">Skill</span>
                <InputText
                    id="@($"skillName-{row.RowId}")"
                    class="form-control"
                    aria-describedby="@($"skillNameLabel-{row.RowId}")"
                    aria-label="Skill name"
                    @bind-Value="row.Name" />
            </div>

            <div class="input-group mb-3">
                <span class="input-group-text" id="@($"skillDescriptionLabel-{row.RowId}")">Description</span>
                <InputTextArea
                    id="@($"skillDescription-{row.RowId}")"
                    class="form-control"
                    aria-describedby="@($"skillDescriptionLabel-{row.RowId}")"
                    aria-label="Skill description"
                    @bind-Value="row.Description" />
            </div>

            <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveSkill(row)" disabled="@(skills.Count == 1)">
                Remove Skill
            </button>
        </div>
    }

    <div class="mb-3">
        <button type="button" class="btn btn-outline-secondary" @onclick="AddSkill">Add Skill</button>
    </div>

    <div class="d-flex gap-2 mb-3">
        <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">
            Back
        </button>
        <button type="button" class="btn btn-outline-primary" @onclick="SaveDraftAsync">
            Save Draft
        </button>
        <button type="button" class="btn btn-primary" @onclick="SaveAndNextAsync">
            Next
        </button>
    </div>

    <p>
        <a href="/sme-questionnaire/privacy">How we use your data (Privacy Notice)</a>
    </p>
}

@code {
    [Parameter]
    public string Token { get; set; } = string.Empty;

    private Guid responseId;
    private bool isLoading = true;
    private string? errorMessage;
    private string? saveMessage;
    private List<SkillRow> skills = new List<SkillRow>();

    protected override async Task OnInitializedAsync()
    {
        if (!Guid.TryParse(Token, out responseId))
        {
            errorMessage = "Invalid questionnaire link.";
            isLoading = false;
            return;
        }

        List<SmeSkill> existingSkills = await SmeQuestionnaireDataService.GetSkillsByResponseIdAsync(responseId);
        skills = existingSkills
            .Select(x => new SkillRow
            {
                Name = x.Name,
                Description = x.Notes,
            })
            .ToList();

        if (skills.Count == 0)
        {
            skills.Add(new SkillRow());
        }

        isLoading = false;
    }

    private void AddSkill()
    {
        skills.Add(new SkillRow());
    }

    private void RemoveSkill(SkillRow row)
    {
        if (skills.Count <= 1)
        {
            return;
        }

        skills.Remove(row);

        if (skills.Count == 0)
        {
            skills.Add(new SkillRow());
        }
    }

    private async Task SaveDraftAsync()
    {
        bool success = await SaveSkillsAsync();
        saveMessage = success ? "Draft saved." : "Unable to save skills.";
    }

    private async Task SaveAndNextAsync()
    {
        bool success = await SaveSkillsAsync();
        if (!success)
        {
            saveMessage = "Unable to save skills.";
            return;
        }

        Navigation.NavigateTo($"/sme-questionnaire/{Token}/facility-tour");
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"/sme-questionnaire/{Token}/software");
    }

    private async Task<bool> SaveSkillsAsync()
    {
        List<SmeSkill> rowsToSave = skills
            .Where(x => !string.IsNullOrWhiteSpace(x.Name))
            .Select(x => new SmeSkill
            {
                Name = x.Name.Trim(),
                Proficiency = ProficiencyLevel.Beginner,
                YearsExperience = null,
                IsPrimary = false,
                Notes = string.IsNullOrWhiteSpace(x.Description) ? null : x.Description.Trim(),
            })
            .ToList();

        return await SmeQuestionnaireDataService.SaveSkillsByResponseIdAsync(responseId, rowsToSave);
    }

    private sealed class SkillRow
    {
        public Guid RowId { get; } = Guid.NewGuid();

        public string Name { get; set; } = string.Empty;

        public string? Description { get; set; }
    }
}
