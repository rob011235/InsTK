@page "/sme-questionnaire/{Token}/skills"
@rendermode InteractiveServer
@attribute [AllowAnonymous]
@using Common.Interfaces
@using Common.Models.SmeQuestionnaire
@inject ISmeQuestionnaireDataService SmeQuestionnaireDataService
@inject NavigationManager Navigation

<PageTitle>SME Questionnaire Skills</PageTitle>

<h1>SME Questionnaire</h1>
<p><strong>Step 2 of 6:</strong> Skills</p>

@if (isLoading)
{
    <p>Loading skills...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(saveMessage))
    {
        <p class="text-success">@saveMessage</p>
    }

    @for (int i = 0; i < skills.Count; i++)
    {
        <div class="border rounded p-3 mb-3">
            <div class="mb-3">
                <label class="form-label" for="@($"skillName-{i}")">Skill Name</label>
                <InputText id="@($"skillName-{i}")" class="form-control" @bind-Value="skills[i].Name" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="@($"skillProficiency-{i}")">Proficiency</label>
                <InputSelect id="@($"skillProficiency-{i}")" class="form-select" @bind-Value="skills[i].Proficiency">
                    @foreach (ProficiencyLevel level in Enum.GetValues<ProficiencyLevel>())
                    {
                        <option value="@level">@level</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label" for="@($"skillYears-{i}")">Years Experience</label>
                <InputNumber id="@($"skillYears-{i}")" class="form-control" @bind-Value="skills[i].YearsExperience" />
            </div>

            <div class="form-check mb-3">
                <InputCheckbox id="@($"skillPrimary-{i}")" class="form-check-input" @bind-Value="skills[i].IsPrimary" />
                <label class="form-check-label" for="@($"skillPrimary-{i}")">Primary skill</label>
            </div>

            <div class="mb-3">
                <label class="form-label" for="@($"skillNotes-{i}")">Notes</label>
                <InputTextArea id="@($"skillNotes-{i}")" class="form-control" @bind-Value="skills[i].Notes" />
            </div>

            <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveSkill(i)" disabled="@(skills.Count == 1)">
                Remove Skill
            </button>
        </div>
    }

    <div class="mb-3">
        <button type="button" class="btn btn-outline-secondary" @onclick="AddSkill">Add Skill</button>
    </div>

    <div class="d-flex gap-2 mb-3">
        <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">
            Back
        </button>
        <button type="button" class="btn btn-outline-primary" @onclick="SaveDraftAsync">
            Save Draft
        </button>
        <button type="button" class="btn btn-primary" @onclick="SaveAndNextAsync">
            Next
        </button>
    </div>

    <p>
        <a href="/sme-questionnaire/privacy">How we use your data (Privacy Notice)</a>
    </p>
}

@code {
    [Parameter]
    public string Token { get; set; } = string.Empty;

    private Guid responseId;
    private bool isLoading = true;
    private string? errorMessage;
    private string? saveMessage;
    private List<SkillRow> skills = new List<SkillRow>();

    protected override async Task OnInitializedAsync()
    {
        if (!Guid.TryParse(Token, out responseId))
        {
            errorMessage = "Invalid questionnaire link.";
            isLoading = false;
            return;
        }

        List<SmeSkill> existingSkills = await SmeQuestionnaireDataService.GetSkillsByResponseIdAsync(responseId);
        skills = existingSkills
            .Select(x => new SkillRow
            {
                Name = x.Name,
                Proficiency = x.Proficiency,
                YearsExperience = x.YearsExperience,
                IsPrimary = x.IsPrimary,
                Notes = x.Notes,
            })
            .ToList();

        if (skills.Count == 0)
        {
            skills.Add(new SkillRow());
        }

        isLoading = false;
    }

    private void AddSkill()
    {
        skills.Add(new SkillRow());
    }

    private void RemoveSkill(int index)
    {
        if (index >= 0 && index < skills.Count)
        {
            skills.RemoveAt(index);
        }

        if (skills.Count == 0)
        {
            skills.Add(new SkillRow());
        }
    }

    private async Task SaveDraftAsync()
    {
        bool success = await SaveSkillsAsync();
        saveMessage = success ? "Draft saved." : "Unable to save skills.";
    }

    private async Task SaveAndNextAsync()
    {
        bool success = await SaveSkillsAsync();
        if (!success)
        {
            saveMessage = "Unable to save skills.";
            return;
        }

        Navigation.NavigateTo($"/sme-questionnaire/{Token}/equipment");
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"/sme-questionnaire/{Token}/profile");
    }

    private async Task<bool> SaveSkillsAsync()
    {
        List<SmeSkill> rowsToSave = skills
            .Where(x => !string.IsNullOrWhiteSpace(x.Name))
            .Select(x => new SmeSkill
            {
                Name = x.Name.Trim(),
                Proficiency = x.Proficiency,
                YearsExperience = x.YearsExperience,
                IsPrimary = x.IsPrimary,
                Notes = string.IsNullOrWhiteSpace(x.Notes) ? null : x.Notes.Trim(),
            })
            .ToList();

        return await SmeQuestionnaireDataService.SaveSkillsByResponseIdAsync(responseId, rowsToSave);
    }

    private sealed class SkillRow
    {
        public string Name { get; set; } = string.Empty;

        public ProficiencyLevel Proficiency { get; set; } = ProficiencyLevel.Beginner;

        public int? YearsExperience { get; set; }

        public bool IsPrimary { get; set; }

        public string? Notes { get; set; }
    }
}
