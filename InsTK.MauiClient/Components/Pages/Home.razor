@page "/"
@inject IClientSettingsService ClientSettingsService
@inject IWorkspaceService WorkspaceService
@inject IWorkstationProfileService WorkstationProfileService
@inject IOllamaModelCatalogService OllamaModelCatalogService
@inject IOllamaService OllamaService
@inject IOllamaRuntimeService OllamaRuntimeService
@inject IBackendSessionService BackendSessionService
@implements IDisposable

<PageTitle>InsTK Instructor Workstation</PageTitle>

<h1>InsTK Instructor Workstation</h1>

<p class="lead">Windows-first MAUI Blazor client for local grading workflows.</p>

@if (isLoading)
{
    <p>Loading workstation configuration...</p>
}
else
{
    <div class="row g-4 mt-1">
        <div class="col-12 col-xl-6">
            <section class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h4 mb-0">Workstation Settings</h2>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ResetToDefaultsAsync">Defaults</button>
                    </div>

                    <EditForm Model="settings" OnSubmit="SaveSettingsAsync">
                        <div class="mb-3">
                            <label class="form-label">Backend Base URL</label>
                            <InputText class="form-control font-monospace" @bind-Value="settings.BackendBaseUrl" />
                            <div class="form-text">Example: https://localhost:5001 or your hosted InsTK server URL.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ollama Base URL</label>
                            <InputText class="form-control font-monospace" @bind-Value="settings.OllamaBaseUrl" />
                            <div class="form-text">Default local endpoint: http://127.0.0.1:11434.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Workspace Root</label>
                            <InputText class="form-control font-monospace" @bind-Value="settings.WorkspaceRoot" />
                            <div class="form-text">Local root folder for cloned repositories, runs, and grading reports.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Required Ollama Version</label>
                            <InputText class="form-control font-monospace" @bind-Value="settings.RequiredOllamaVersion" />
                            <div class="form-text">Pinned managed runtime version required for grading on this workstation.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Required Windows Zip SHA-256</label>
                            <InputText class="form-control font-monospace" @bind-Value="settings.RequiredOllamaWindowsZipSha256" />
                            <div class="form-text">Expected SHA-256 for the pinned official `ollama-windows-amd64.zip` asset.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Primary Ollama Model</label>
                            <InputSelect class="form-select font-monospace" @bind-Value="settings.PrimaryOllamaModel">
                                @foreach (var model in supportedModels)
                                {
                                    <option value="@model.Name">@model.Name</option>
                                }
                            </InputSelect>
                            <div class="form-text">Only models that fit the current machine profile are offered here.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Fallback Ollama Model</label>
                            <InputSelect class="form-select font-monospace" @bind-Value="settings.FallbackOllamaModel">
                                @foreach (var model in supportedModels)
                                {
                                    <option value="@model.Name">@model.Name</option>
                                }
                            </InputSelect>
                            <div class="form-text">Fallback used when the primary model cannot be loaded.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Managed Ollama Root</label>
                            <InputText class="form-control font-monospace" @bind-Value="settings.ManagedOllamaRoot" />
                            <div class="form-text">Root folder where the MAUI client will manage the Ollama runtime.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Ollama Models Root</label>
                            <InputText class="form-control font-monospace" @bind-Value="settings.OllamaModelsRoot" />
                            <div class="form-text">Root folder where Ollama should store downloaded models.</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary" disabled="@isSaving">Save Settings</button>
                            <button type="button" class="btn btn-outline-primary" @onclick="RefreshStatusAsync" disabled="@isRefreshing">Refresh Status</button>
                        </div>
                    </EditForm>

                    @if (!string.IsNullOrWhiteSpace(saveMessage))
                    {
                        <div class="alert alert-success mt-3 mb-0" role="status">@saveMessage</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="alert alert-danger mt-3 mb-0" role="alert">@errorMessage</div>
                    }
                </div>
            </section>
        </div>

        <div class="col-12 col-xl-6">
            <section class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h4">Current Status</h2>

                    @if (workspace is not null)
                    {
                        <div class="status-panel mb-4">
                            <div class="status-panel__header">
                                <h3 class="h6 mb-0">Workspace</h3>
                                <span class="badge @(workspace.Exists ? "text-bg-success" : "text-bg-secondary")">
                                    @(workspace.Exists ? "Ready" : "Not Created")
                                </span>
                            </div>

                            <dl class="status-list">
                                <dt>Root</dt>
                                <dd>@workspace.RootPath</dd>
                                <dt>Repositories</dt>
                                <dd>@workspace.RepositoriesPath</dd>
                                <dt>Runs</dt>
                                <dd>@workspace.GradingRunsPath</dd>
                                <dt>Reports</dt>
                                <dd>@workspace.ReportsPath</dd>
                            </dl>
                        </div>
                    }

                    @if (workstationProfile is not null)
                    {
                        <div class="status-panel mb-4">
                            <div class="status-panel__header">
                                <h3 class="h6 mb-0">Machine Profile</h3>
                                <span class="badge @(IsConfiguredPrimaryModelRecommended() ? "text-bg-success" : "text-bg-warning")">
                                    @(IsConfiguredPrimaryModelRecommended() ? "Model Match" : "Model Mismatch")
                                </span>
                            </div>

                            <dl class="status-list">
                                <dt>Operating System</dt>
                                <dd>@workstationProfile.OperatingSystem</dd>
                                <dt>Logical CPU</dt>
                                <dd>@workstationProfile.ProcessorCount</dd>
                                <dt>Total RAM</dt>
                                <dd>@FormatGiB(workstationProfile.TotalMemoryBytes) GiB</dd>
                                <dt>Available RAM</dt>
                                <dd>@FormatGiB(workstationProfile.AvailableMemoryBytes) GiB</dd>
                                <dt>Recommended Primary</dt>
                                <dd>@workstationProfile.RecommendedPrimaryModel</dd>
                                <dt>Recommendation</dt>
                                <dd>@workstationProfile.RecommendationSummary</dd>
                                <dt>Configured Primary</dt>
                                <dd>@settings.PrimaryOllamaModel</dd>
                                <dt>Supported Models</dt>
                                <dd>@string.Join(", ", supportedModels.Select(model => model.Name))</dd>
                            </dl>
                        </div>
                    }

                    @if (backendStatus is not null)
                    {
                        <div class="status-panel mb-4">
                            <div class="status-panel__header">
                                <h3 class="h6 mb-0">Backend Bootstrap</h3>
                                <span class="badge @(backendStatus.IsReachable ? "text-bg-success" : "text-bg-warning")">
                                    @(backendStatus.IsReachable ? "Reachable" : "Attention")
                                </span>
                            </div>

                            <dl class="status-list">
                                <dt>Base URL</dt>
                                <dd>@DisplayOrPlaceholder(backendStatus.BaseUrl)</dd>
                                <dt>Auth State</dt>
                                <dd>@backendStatus.AuthenticationState</dd>
                                <dt>Summary</dt>
                                <dd>@backendStatus.Summary</dd>
                                @if (!string.IsNullOrWhiteSpace(backendStatus.ErrorMessage))
                                {
                                    <dt>Error</dt>
                                    <dd>@backendStatus.ErrorMessage</dd>
                                }
                            </dl>
                        </div>
                    }

                    @if (ollamaStatus is not null)
                    {
                        <div class="status-panel mb-4">
                            <div class="status-panel__header">
                                <h3 class="h6 mb-0">Ollama Runtime Setup</h3>
                                <span class="badge @GetRuntimeBadgeClass(ollamaRuntimeStatus?.State ?? OllamaRuntimeState.Missing)">
                                    @GetRuntimeLabel(ollamaRuntimeStatus?.State ?? OllamaRuntimeState.Missing)
                                </span>
                            </div>

                            @if (ollamaRuntimeStatus is not null)
                            {
                                <dl class="status-list">
                                    <dt>Managed Runtime</dt>
                                    <dd>@ollamaRuntimeStatus.ManagedExecutablePath</dd>
                                    <dt>Required Version</dt>
                                    <dd>@ollamaRuntimeStatus.RequiredVersion</dd>
                                    <dt>Detected Version</dt>
                                    <dd>@DisplayOrPlaceholder(ollamaRuntimeStatus.DetectedVersion)</dd>
                                    <dt>Server Version</dt>
                                    <dd>@DisplayOrPlaceholder(ollamaRuntimeStatus.ServerVersion)</dd>
                                    <dt>Zip SHA-256</dt>
                                    <dd>@ollamaRuntimeStatus.RequiredWindowsZipSha256</dd>
                                    <dt>Models Root</dt>
                                    <dd>@ollamaRuntimeStatus.ModelsRoot</dd>
                                    <dt>Primary Model</dt>
                                    <dd>
                                        @ollamaRuntimeStatus.PrimaryModel
                                        <span class="runtime-chip @(ollamaRuntimeStatus.HasPrimaryModel ? "runtime-chip--ready" : "runtime-chip--missing")">
                                            @(ollamaRuntimeStatus.HasPrimaryModel ? "Installed" : "Missing")
                                        </span>
                                    </dd>
                                    <dt>Fallback Model</dt>
                                    <dd>
                                        @ollamaRuntimeStatus.FallbackModel
                                        <span class="runtime-chip @(ollamaRuntimeStatus.HasFallbackModel ? "runtime-chip--ready" : "runtime-chip--missing")">
                                            @(ollamaRuntimeStatus.HasFallbackModel ? "Installed" : "Missing")
                                        </span>
                                    </dd>
                                    <dt>Summary</dt>
                                    <dd>@ollamaRuntimeStatus.Summary</dd>
                                    @if (!string.IsNullOrWhiteSpace(ollamaRuntimeStatus.ErrorMessage))
                                    {
                                        <dt>Error</dt>
                                        <dd>@ollamaRuntimeStatus.ErrorMessage</dd>
                                    }
                                </dl>

                                <div class="runtime-actions mt-3">
                                    <button type="button" class="btn btn-primary" @onclick="InstallOrUpdateRuntimeAsync" disabled="@isRuntimeBusy">Install or Update Runtime</button>
                                    <button type="button" class="btn btn-outline-primary" @onclick="StartRuntimeAsync" disabled="@isRuntimeBusy">Start Runtime</button>
                                    <button type="button" class="btn btn-outline-secondary" @onclick="DownloadRequiredModelsAsync" disabled="@isRuntimeBusy">Download Primary + Fallback</button>
                                </div>

                                <div class="runtime-model-admin mt-3">
                                    <div class="mb-3">
                                        <label class="form-label">Download Model</label>
                                        <InputSelect class="form-select font-monospace" @bind-Value="selectedModelToDownload">
                                            @foreach (var model in supportedModels)
                                            {
                                                <option value="@model.Name">@model.Name</option>
                                            }
                                        </InputSelect>
                                        @if (selectedDownloadModelOption is not null)
                                        {
                                            <div class="form-text">@selectedDownloadModelOption.DisplayName · @selectedDownloadModelOption.DownloadSizeLabel · @selectedDownloadModelOption.Notes</div>
                                        }
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Remove Installed Model</label>
                                        <InputSelect class="form-select font-monospace" @bind-Value="selectedInstalledModelToRemove">
                                            <option value="">Select installed model</option>
                                            @foreach (var model in installedModels)
                                            {
                                                <option value="@model">@model</option>
                                            }
                                        </InputSelect>
                                        <div class="form-text">Only models currently installed in the local Ollama store appear here.</div>
                                    </div>

                                    <div class="runtime-actions">
                                        <button type="button" class="btn btn-outline-dark" @onclick="DownloadSelectedModelAsync" disabled="@isRuntimeBusy || string.IsNullOrWhiteSpace(selectedModelToDownload)">Download Selected Model</button>
                                        <button type="button" class="btn btn-outline-danger" @onclick="RemoveSelectedModelAsync" disabled="@isRuntimeBusy || string.IsNullOrWhiteSpace(selectedInstalledModelToRemove)">Remove Selected Model</button>
                                        <button type="button" class="btn btn-outline-secondary" @onclick="ApplyRecommendedModels" disabled="@isRuntimeBusy || recommendedPrimaryModel is null || recommendedFallbackModel is null">Use Recommended Models</button>
                                    </div>
                                </div>

                                @if (isRuntimeBusy)
                                {
                                    <div class="runtime-busy mt-3" role="status" aria-live="polite">
                                        <span class="spinner-border spinner-border-sm runtime-busy__spinner" aria-hidden="true"></span>
                                        <div>
                                            <div class="runtime-busy__title">@currentRuntimeOperation</div>
                                            <div class="runtime-busy__detail">This can take several minutes for large models. New activity will appear below.</div>
                                        </div>
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(runtimeMessage))
                                {
                                    <div class="alert alert-success mt-3 mb-0" role="status">@runtimeMessage</div>
                                }

                                @if (!string.IsNullOrWhiteSpace(runtimeErrorMessage))
                                {
                                    <div class="alert alert-danger mt-3 mb-0" role="alert">@runtimeErrorMessage</div>
                                }

                                @if (runtimeActivityLog.Count > 0)
                                {
                                    <div class="runtime-log mt-3">
                                        <h4 class="h6 mb-2">Runtime Activity</h4>
                                        <ul class="runtime-log__list">
                                            @foreach (var entry in runtimeActivityLog)
                                            {
                                                <li class="runtime-log__entry @(entry.IsError ? "runtime-log__entry--error" : string.Empty)">@entry.Message</li>
                                            }
                                        </ul>
                                    </div>
                                }
                            }
                        </div>

                        <div class="status-panel">
                            <div class="status-panel__header">
                                <h3 class="h6 mb-0">Ollama</h3>
                                <span class="badge @(ollamaStatus.IsReachable ? "text-bg-success" : "text-bg-warning")">
                                    @(ollamaStatus.IsReachable ? "Reachable" : "Attention")
                                </span>
                            </div>

                            <dl class="status-list">
                                <dt>Base URL</dt>
                                <dd>@DisplayOrPlaceholder(ollamaStatus.BaseUrl)</dd>
                                <dt>Server Version</dt>
                                <dd>@DisplayOrPlaceholder(ollamaStatus.ServerVersion)</dd>
                                <dt>Models</dt>
                                <dd>@ollamaStatus.ModelCount</dd>
                                <dt>Summary</dt>
                                <dd>@ollamaStatus.Summary</dd>
                                @if (!string.IsNullOrWhiteSpace(ollamaStatus.ErrorMessage))
                                {
                                    <dt>Error</dt>
                                    <dd>@ollamaStatus.ErrorMessage</dd>
                                }
                            </dl>
                        </div>
                    }
                </div>
            </section>
        </div>
    </div>
}

@code {
    private const int MaxRuntimeLogEntries = 12;
    private DesktopClientSettings settings = new();
    private WorkspaceSnapshot? workspace;
    private WorkstationProfile? workstationProfile;
    private IReadOnlyList<OllamaModelOption> supportedModels = Array.Empty<OllamaModelOption>();
    private OllamaModelOption? recommendedPrimaryModel;
    private OllamaModelOption? recommendedFallbackModel;
    private OllamaConnectionStatus? ollamaStatus;
    private OllamaRuntimeStatus? ollamaRuntimeStatus;
    private BackendConnectionStatus? backendStatus;
    private bool isLoading = true;
    private bool isSaving;
    private bool isRefreshing;
    private bool isRuntimeBusy;
    private string? saveMessage;
    private string? errorMessage;
    private string? currentRuntimeOperation;
    private string? runtimeMessage;
    private string? runtimeErrorMessage;
    private string? selectedModelToDownload;
    private string? selectedInstalledModelToRemove;
    private readonly List<OllamaRuntimeActivityEventArgs> runtimeActivityLog = new();

    private IReadOnlyList<string> installedModels =>
        ollamaStatus?.ModelNames
            .OrderBy(static model => model, StringComparer.OrdinalIgnoreCase)
            .ToArray()
        ?? Array.Empty<string>();

    private OllamaModelOption? selectedDownloadModelOption =>
        supportedModels.FirstOrDefault(model => string.Equals(model.Name, selectedModelToDownload, StringComparison.OrdinalIgnoreCase));

    /// <summary>
    /// Loads persisted workstation settings and probes the local service state.
    /// </summary>
    /// <returns>A task that completes when the page state has been initialized.</returns>
    protected override async Task OnInitializedAsync()
    {
        OllamaRuntimeService.ActivityReported += HandleRuntimeActivityReported;
        settings = await ClientSettingsService.GetAsync();
        await RefreshStatusAsync();
        isLoading = false;
    }

    /// <summary>
    /// Saves the current workstation settings and refreshes dependent status checks.
    /// </summary>
    /// <returns>A task that completes when the settings have been saved.</returns>
    private async Task SaveSettingsAsync()
    {
        isSaving = true;
        saveMessage = null;
        errorMessage = null;

        try
        {
            await ClientSettingsService.SaveAsync(settings);
            settings = await ClientSettingsService.GetAsync();
            await RefreshStatusAsync();
            saveMessage = "Settings saved and workstation status refreshed.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    /// <summary>
    /// Resets the workstation settings to the default local values and saves them.
    /// </summary>
    /// <returns>A task that completes when the reset is finished.</returns>
    private async Task ResetToDefaultsAsync()
    {
        settings = new DesktopClientSettings
        {
            WorkspaceRoot = Path.Combine(FileSystem.Current.AppDataDirectory, "Workspace")
        };

        saveMessage = null;
        errorMessage = null;
        await SaveSettingsAsync();
    }

    /// <summary>
    /// Refreshes workspace, backend, and Ollama status information for the workstation.
    /// </summary>
    /// <returns>A task that completes when the refresh has finished.</returns>
    private async Task RefreshStatusAsync()
    {
        isRefreshing = true;
        saveMessage = null;
        errorMessage = null;

        try
        {
            workspace = await WorkspaceService.EnsureCreatedAsync();
            workstationProfile = await WorkstationProfileService.GetProfileAsync();
            supportedModels = OllamaModelCatalogService.GetSupportedModels(workstationProfile);
            recommendedPrimaryModel = OllamaModelCatalogService.GetRecommendedPrimaryModel(workstationProfile);
            recommendedFallbackModel = OllamaModelCatalogService.GetRecommendedFallbackModel(workstationProfile);
            NormalizeSelectedModels();
            backendStatus = await BackendSessionService.GetStatusAsync();
            ollamaStatus = await OllamaService.GetStatusAsync();
            ollamaRuntimeStatus = await OllamaRuntimeService.GetRuntimeStatusAsync();
            selectedInstalledModelToRemove = string.IsNullOrWhiteSpace(selectedInstalledModelToRemove) || !installedModels.Contains(selectedInstalledModelToRemove, StringComparer.OrdinalIgnoreCase)
                ? installedModels.FirstOrDefault()
                : selectedInstalledModelToRemove;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isRefreshing = false;
        }
    }

    /// <summary>
    /// Downloads and installs or updates the managed Ollama runtime.
    /// </summary>
    /// <returns>A task that completes when the operation has finished.</returns>
    private async Task InstallOrUpdateRuntimeAsync()
    {
        await RunRuntimeOperationAsync(
            "Installing or updating managed Ollama runtime",
            () => OllamaRuntimeService.InstallOrUpdateManagedRuntimeAsync());
    }

    /// <summary>
    /// Starts the managed Ollama runtime.
    /// </summary>
    /// <returns>A task that completes when the operation has finished.</returns>
    private async Task StartRuntimeAsync()
    {
        await RunRuntimeOperationAsync(
            "Starting managed Ollama runtime",
            () => OllamaRuntimeService.StartManagedRuntimeAsync());
    }

    /// <summary>
    /// Downloads the required grading models for the workstation policy.
    /// </summary>
    /// <returns>A task that completes when the operation has finished.</returns>
    private async Task DownloadRequiredModelsAsync()
    {
        await RunRuntimeOperationAsync(
            "Downloading required Ollama models",
            () => OllamaRuntimeService.EnsureRequiredModelsAsync());
    }

    /// <summary>
    /// Downloads the currently selected supported model.
    /// </summary>
    /// <returns>A task that completes when the operation has finished.</returns>
    private async Task DownloadSelectedModelAsync()
    {
        var model = selectedModelToDownload;

        await RunRuntimeOperationAsync(
            string.IsNullOrWhiteSpace(model) ? "Downloading selected Ollama model" : $"Downloading Ollama model {model}",
            () => OllamaRuntimeService.EnsureModelAsync(model ?? string.Empty));
    }

    /// <summary>
    /// Removes the currently selected installed model from the local Ollama store.
    /// </summary>
    /// <returns>A task that completes when the operation has finished.</returns>
    private async Task RemoveSelectedModelAsync()
    {
        var model = selectedInstalledModelToRemove;

        await RunRuntimeOperationAsync(
            string.IsNullOrWhiteSpace(model) ? "Removing selected Ollama model" : $"Removing Ollama model {model}",
            () => OllamaRuntimeService.RemoveModelAsync(model ?? string.Empty));
    }

    /// <summary>
    /// Applies the machine-recommended primary and fallback model selections to the settings form.
    /// </summary>
    private void ApplyRecommendedModels()
    {
        if (recommendedPrimaryModel is null || recommendedFallbackModel is null)
        {
            return;
        }

        settings.PrimaryOllamaModel = recommendedPrimaryModel.Name;
        settings.FallbackOllamaModel = recommendedFallbackModel.Name;
        selectedModelToDownload ??= recommendedPrimaryModel.Name;
    }

    /// <summary>
    /// Runs a managed Ollama runtime operation and refreshes workstation status afterward.
    /// </summary>
    /// <param name="operation">The operation to execute.</param>
    /// <returns>A task that completes when the operation and refresh have finished.</returns>
    private async Task RunRuntimeOperationAsync(string operationLabel, Func<Task<OllamaRuntimeOperationResult>> operation)
    {
        isRuntimeBusy = true;
        currentRuntimeOperation = operationLabel;
        runtimeMessage = null;
        runtimeErrorMessage = null;
        runtimeActivityLog.Clear();
        runtimeActivityLog.Add(new OllamaRuntimeActivityEventArgs($"{operationLabel} started.", false));
        saveMessage = null;
        errorMessage = null;

        try
        {
            var result = await operation();

            if (result.IsSuccess)
            {
                runtimeMessage = result.Summary;
            }
            else
            {
                runtimeErrorMessage = string.IsNullOrWhiteSpace(result.ErrorMessage)
                    ? result.Summary
                    : $"{result.Summary} {result.ErrorMessage}";
            }

            await RefreshStatusAsync();
        }
        catch (Exception ex)
        {
            runtimeErrorMessage = ex.Message;
        }
        finally
        {
            isRuntimeBusy = false;
            currentRuntimeOperation = null;
        }
    }

    /// <summary>
    /// Handles runtime activity updates reported by the managed Ollama service.
    /// </summary>
    /// <param name="sender">The event sender.</param>
    /// <param name="eventArgs">The reported activity details.</param>
    private void HandleRuntimeActivityReported(object? sender, OllamaRuntimeActivityEventArgs eventArgs)
    {
        _ = InvokeAsync(() =>
        {
            if (!string.IsNullOrWhiteSpace(eventArgs.CollapseKey))
            {
                var existingIndex = runtimeActivityLog.FindIndex(
                    entry => string.Equals(entry.CollapseKey, eventArgs.CollapseKey, StringComparison.Ordinal));

                if (existingIndex >= 0)
                {
                    runtimeActivityLog[existingIndex] = eventArgs;
                }
                else
                {
                    runtimeActivityLog.Insert(0, eventArgs);
                }
            }
            else
            {
                runtimeActivityLog.Insert(0, eventArgs);
            }

            if (runtimeActivityLog.Count > MaxRuntimeLogEntries)
            {
                runtimeActivityLog.RemoveAt(runtimeActivityLog.Count - 1);
            }

            StateHasChanged();
        });
    }

    /// <summary>
    /// Returns a fallback label when a configuration value has not been supplied.
    /// </summary>
    /// <param name="value">The value to render.</param>
    /// <returns>The supplied value or a placeholder string.</returns>
    private static string DisplayOrPlaceholder(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not configured" : value;
    }

    /// <summary>
    /// Formats a byte count as gibibytes for workstation hardware display.
    /// </summary>
    /// <param name="bytes">The byte count to format.</param>
    /// <returns>The formatted GiB string.</returns>
    private static string FormatGiB(ulong bytes)
    {
        return (bytes / (1024d * 1024d * 1024d)).ToString("0.0");
    }

    /// <summary>
    /// Determines whether the configured primary model matches the machine recommendation.
    /// </summary>
    /// <returns><see langword="true"/> when the configured primary model matches the current recommendation.</returns>
    private bool IsConfiguredPrimaryModelRecommended()
    {
        return workstationProfile is not null
            && recommendedPrimaryModel is not null
            && string.Equals(settings.PrimaryOllamaModel, recommendedPrimaryModel.Name, StringComparison.OrdinalIgnoreCase);
    }

    /// <summary>
    /// Aligns configured and selected model values with the current machine-supported model catalog.
    /// </summary>
    private void NormalizeSelectedModels()
    {
        if (supportedModels.Count == 0)
        {
            return;
        }

        recommendedPrimaryModel ??= supportedModels[0];
        recommendedFallbackModel ??= supportedModels[0];

        if (!supportedModels.Any(model => string.Equals(model.Name, settings.PrimaryOllamaModel, StringComparison.OrdinalIgnoreCase)))
        {
            settings.PrimaryOllamaModel = recommendedPrimaryModel.Name;
        }

        if (!supportedModels.Any(model => string.Equals(model.Name, settings.FallbackOllamaModel, StringComparison.OrdinalIgnoreCase)))
        {
            settings.FallbackOllamaModel = recommendedFallbackModel.Name;
        }

        if (!supportedModels.Any(model => string.Equals(model.Name, selectedModelToDownload, StringComparison.OrdinalIgnoreCase)))
        {
            selectedModelToDownload = recommendedPrimaryModel.Name;
        }
    }

    /// <summary>
    /// Maps the workstation runtime state to a badge style.
    /// </summary>
    /// <param name="state">The runtime state to classify.</param>
    /// <returns>The CSS class to apply.</returns>
    private static string GetRuntimeBadgeClass(OllamaRuntimeState state)
    {
        return state == OllamaRuntimeState.Ready ? "text-bg-success" : "text-bg-warning";
    }

    /// <summary>
    /// Maps the workstation runtime state to a short label.
    /// </summary>
    /// <param name="state">The runtime state to classify.</param>
    /// <returns>The display label.</returns>
    private static string GetRuntimeLabel(OllamaRuntimeState state)
    {
        return state switch
        {
            OllamaRuntimeState.Missing => "Missing",
            OllamaRuntimeState.WrongVersion => "Wrong Version",
            OllamaRuntimeState.EndpointUnavailable => "Not Running",
            OllamaRuntimeState.ConflictingInstance => "Conflict",
            OllamaRuntimeState.ModelMissing => "Model Missing",
            OllamaRuntimeState.Ready => "Ready",
            _ => "Attention"
        };
    }

    /// <summary>
    /// Detaches runtime event subscriptions when the component is disposed.
    /// </summary>
    public void Dispose()
    {
        OllamaRuntimeService.ActivityReported -= HandleRuntimeActivityReported;
    }
}
