@page "/brightspace"
@inject IClientSettingsService ClientSettingsService
@inject IBrightspaceAutomationService BrightspaceAutomationService
@implements IDisposable

<PageTitle>Brightspace</PageTitle>

<div class="brightspace-page">
    <section class="brightspace-hero">
        <p class="brightspace-eyebrow">Local LMS automation</p>
        <h1>Brightspace</h1>
        <p class="brightspace-description">Sign into Brightspace locally, save the workstation browser session, then discover available courses and terms without routing student data through the server.</p>
    </section>

    <section class="brightspace-panel">
        <div class="brightspace-meta">
            <span class="brightspace-chip">Browser: @settings.BrightspaceBrowserChannel</span>
            <span class="brightspace-chip">Base URL: @DisplayOrPlaceholder(settings.BrightspaceBaseUrl)</span>
            <span class="brightspace-chip">Session: @(hasSavedSession ? "Saved" : "Missing")</span>
        </div>

        <div class="brightspace-status @GetStatusClass()">
            <div class="brightspace-status__header">
                <strong>@GetStatusTitle()</strong>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="RefreshSettingsAsync" disabled="@isBusy">
                    Refresh Settings
                </button>
            </div>
            <div>@GetStatusSummary()</div>
            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="brightspace-status__detail">@errorMessage</div>
            }
        </div>

        <dl class="status-list">
            <dt>Brightspace Base URL</dt>
            <dd>@DisplayOrPlaceholder(settings.BrightspaceBaseUrl)</dd>
            <dt>Session State</dt>
            <dd>@settings.BrightspaceStatePath</dd>
            <dt>Submission Map</dt>
            <dd>@settings.BrightspaceSubmissionMapOutPath</dd>
        </dl>

        <div class="row g-3 mt-1">
            <div class="col-12 col-lg-8">
                <label class="form-label" for="brightspace-base-url">Brightspace Base URL</label>
                <input id="brightspace-base-url" class="form-control font-monospace" @bind="settings.BrightspaceBaseUrl" @bind:event="oninput" />
                <div class="form-text">Use the Brightspace root or home URL, not a Quick Eval deep link.</div>
                <div class="form-text">Current value: @DisplayOrPlaceholder(settings.BrightspaceBaseUrl)</div>
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label" for="brightspace-browser-channel">Browser Channel</label>
                <input id="brightspace-browser-channel" class="form-control font-monospace" @bind="settings.BrightspaceBrowserChannel" @bind:event="oninput" />
                <div class="form-text">Usually `msedge` on Windows.</div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-3 flex-wrap">
            <button type="button" class="btn btn-primary" @onclick="SaveBrightspaceSettingsAsync" disabled="@isBusy">
                @(isBusy && currentOperation == "save-settings" ? "Saving..." : "Save Brightspace Settings")
            </button>
            <button type="button" class="btn btn-outline-primary" @onclick="OpenLoginAsync" disabled="@isBusy">
                @(isBusy && currentOperation == "login" ? "Opening..." : "Open Brightspace Login")
            </button>
            <button type="button" class="btn btn-outline-primary" @onclick="SaveSessionAsync" disabled="@isBusy">
                @(isBusy && currentOperation == "save-session" ? "Saving..." : "Save Session")
            </button>
            <button type="button" class="btn btn-outline-secondary" @onclick="DiscoverCoursesAsync" disabled="@isBusy">
                @(isBusy && currentOperation == "discover-courses" ? "Discovering..." : "Discover Courses")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="alert alert-success mt-3 mb-0" role="status">
                <div>@successMessage</div>
                @if (!string.IsNullOrWhiteSpace(lastSavedBaseUrl))
                {
                    <div class="mt-1"><strong>Saved Base URL:</strong> @lastSavedBaseUrl</div>
                }
            </div>
        }
    </section>

    <section class="brightspace-panel">
        <div class="d-flex justify-content-between align-items-center gap-3">
            <h2 class="h4 mb-0">Course Discovery</h2>
            @if (courseCatalogResult is not null)
            {
                <span class="brightspace-chip">@courseCatalogResult.Courses.Count course(s)</span>
            }
        </div>

        @if (courseCatalogResult is null)
        {
            <div class="brightspace-empty-state">No Brightspace course catalog has been discovered yet.</div>
        }
        else
        {
            <div class="row g-3 mt-1">
                <div class="col-12 col-md-4">
                    <label class="form-label" for="brightspace-term-filter">Term</label>
                    <select id="brightspace-term-filter" class="form-select" @bind="selectedTermLabel">
                        @foreach (var term in availableTermLabels)
                        {
                            <option value="@term">@term</option>
                        }
                    </select>
                    <div class="form-text">Filter the discovered course list by inferred term label.</div>
                </div>

                <div class="col-12 col-md-8">
                    <label class="form-label" for="brightspace-course-select">Course</label>
                    <select id="brightspace-course-select" class="form-select" @bind="selectedCourseId">
                        @foreach (var course in filteredCourses)
                        {
                            <option value="@course.CourseId">@course.Name</option>
                        }
                    </select>
                    <div class="form-text">Select the course you want to work with next.</div>
                </div>
            </div>

            @if (selectedCourse is not null)
            {
                <div class="brightspace-results">
                    <article class="brightspace-entry">
                        <header class="brightspace-entry__header">
                            <div>
                                <h3 class="h6 mb-1">@selectedCourse.Name</h3>
                                <div class="text-body-secondary">@selectedCourse.TermLabel</div>
                            </div>
                            <span class="brightspace-entry__type">Course</span>
                        </header>
                        <dl class="status-list">
                            <dt>Course ID</dt>
                            <dd>@selectedCourse.CourseId</dd>
                            <dt>Course Code</dt>
                            <dd>@DisplayOrPlaceholder(selectedCourse.CourseCode)</dd>
                            <dt>Course URL</dt>
                            <dd>@selectedCourse.Url</dd>
                        </dl>
                    </article>
                </div>
            }
            else if (filteredCourses.Count == 0)
            {
                <div class="brightspace-empty-state">No courses matched the selected term filter.</div>
            }
        }
    </section>

    <section class="brightspace-panel">
        <div class="d-flex justify-content-between align-items-center gap-3">
            <h2 class="h4 mb-0">Activity Log</h2>
            @if (activityLog.Count > 0)
            {
                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearLog" disabled="@isBusy">Clear Log</button>
            }
        </div>

        @if (activityLog.Count == 0)
        {
            <div class="brightspace-empty-state">No Brightspace activity yet.</div>
        }
        else
        {
            <ul class="runtime-log__list mt-3">
                @foreach (var entry in activityLog)
                {
                    <li class="runtime-log__entry @(entry.IsError ? "runtime-log__entry--error" : string.Empty)">@entry.Message</li>
                }
            </ul>
        }
    </section>
</div>

@code {
    private const string AllTermsLabel = "All Terms";

    private readonly List<BrightspaceActivityEventArgs> activityLog = [];
    private DesktopClientSettings settings = new();
    private BrightspaceCourseCatalogResult? courseCatalogResult;
    private bool isBusy;
    private string? errorMessage;
    private string? successMessage;
    private string? lastSavedBaseUrl;
    private string? currentOperation;
    private string selectedTermLabel = AllTermsLabel;
    private string? selectedCourseId;

    private bool isConfigured => !string.IsNullOrWhiteSpace(settings.BrightspaceBaseUrl);
    private bool hasSavedSession => File.Exists(settings.BrightspaceStatePath);

    private IReadOnlyList<string> availableTermLabels =>
        courseCatalogResult is null
            ? [AllTermsLabel]
            : [AllTermsLabel, .. courseCatalogResult.TermLabels];

    private IReadOnlyList<BrightspaceCourseOption> filteredCourses =>
        courseCatalogResult is null
            ? Array.Empty<BrightspaceCourseOption>()
            : string.Equals(selectedTermLabel, AllTermsLabel, StringComparison.Ordinal)
                ? courseCatalogResult.Courses
                : courseCatalogResult.Courses
                    .Where(course => string.Equals(course.TermLabel, selectedTermLabel, StringComparison.OrdinalIgnoreCase))
                    .ToArray();

    private BrightspaceCourseOption? selectedCourse =>
        filteredCourses.FirstOrDefault(course => string.Equals(course.CourseId, selectedCourseId, StringComparison.OrdinalIgnoreCase))
        ?? filteredCourses.FirstOrDefault();

    protected override async Task OnInitializedAsync()
    {
        BrightspaceAutomationService.ActivityReported += HandleActivityReported;
        await RefreshSettingsAsync();
    }

    private async Task RefreshSettingsAsync()
    {
        settings = await ClientSettingsService.GetAsync();
        errorMessage = null;
        successMessage = null;
        lastSavedBaseUrl = settings.BrightspaceBaseUrl;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveBrightspaceSettingsAsync()
    {
        isBusy = true;
        currentOperation = "save-settings";
        errorMessage = null;
        successMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            await ClientSettingsService.SaveAsync(settings);
            settings = await ClientSettingsService.GetAsync();
            successMessage = "Brightspace settings saved. Next step: open Brightspace login and save the browser session.";
            lastSavedBaseUrl = settings.BrightspaceBaseUrl;
            activityLog.Insert(0, new BrightspaceActivityEventArgs("Saved Brightspace settings."));
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isBusy = false;
            currentOperation = null;
        }
    }

    private async Task OpenLoginAsync()
    {
        if (!isConfigured)
        {
            errorMessage = "Set and save the Brightspace base URL first.";
            return;
        }

        activityLog.Insert(0, new BrightspaceActivityEventArgs("Starting Brightspace login flow..."));
        await RunBusyOperationAsync("login", BrightspaceAutomationService.StartLoginAsync);
    }

    private async Task SaveSessionAsync()
    {
        if (!BrightspaceAutomationService.IsLoginInProgress)
        {
            errorMessage = "No Brightspace login browser is currently open. Click 'Open Brightspace Login' first.";
            return;
        }

        await RunBusyOperationAsync("save-session", BrightspaceAutomationService.SaveLoginSessionAsync);
        await RefreshSettingsAsync();
        successMessage = "Brightspace session saved. Next step: discover available courses.";
    }

    private async Task DiscoverCoursesAsync()
    {
        if (!isConfigured)
        {
            errorMessage = "Set and save the Brightspace base URL first.";
            return;
        }

        if (!hasSavedSession)
        {
            errorMessage = "No saved Brightspace session was found yet. Open the login flow and save the session first.";
            return;
        }

        isBusy = true;
        currentOperation = "discover-courses";
        errorMessage = null;
        successMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            courseCatalogResult = await BrightspaceAutomationService.DiscoverCoursesAsync();
            selectedTermLabel = AllTermsLabel;
            selectedCourseId = courseCatalogResult.Courses.FirstOrDefault()?.CourseId;
            successMessage = $"Discovered {courseCatalogResult.Courses.Count} Brightspace course(s).";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isBusy = false;
            currentOperation = null;
        }
    }

    private async Task RunBusyOperationAsync(string operation, Func<CancellationToken, Task> action)
    {
        isBusy = true;
        currentOperation = operation;
        errorMessage = null;
        successMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            await action(CancellationToken.None);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isBusy = false;
            currentOperation = null;
        }
    }

    private void HandleActivityReported(object? sender, BrightspaceActivityEventArgs eventArgs)
    {
        _ = InvokeAsync(() =>
        {
            activityLog.Insert(0, eventArgs);

            if (activityLog.Count > 50)
            {
                activityLog.RemoveAt(activityLog.Count - 1);
            }

            StateHasChanged();
        });
    }

    private void ClearLog()
    {
        activityLog.Clear();
        errorMessage = null;
        successMessage = null;
    }

    private string GetStatusClass()
    {
        if (!isConfigured)
        {
            return "brightspace-status--warning";
        }

        if (BrightspaceAutomationService.IsLoginInProgress)
        {
            return "brightspace-status--info";
        }

        if (!hasSavedSession)
        {
            return "brightspace-status--warning";
        }

        if (courseCatalogResult is null)
        {
            return "brightspace-status--info";
        }

        return "brightspace-status--success";
    }

    private string GetStatusTitle()
    {
        if (!isConfigured)
        {
            return "Brightspace is not configured";
        }

        if (BrightspaceAutomationService.IsLoginInProgress)
        {
            return "Brightspace login is in progress";
        }

        if (!hasSavedSession)
        {
            return "Brightspace session is missing";
        }

        if (courseCatalogResult is null)
        {
            return "Brightspace session is ready";
        }

        return "Brightspace courses are ready";
    }

    private string GetStatusSummary()
    {
        if (!isConfigured)
        {
            return "Set the Brightspace base URL before using this page.";
        }

        if (BrightspaceAutomationService.IsLoginInProgress)
        {
            return "Complete the manual sign-in flow in the opened browser, then save the session back to the workstation.";
        }

        if (!hasSavedSession)
        {
            return "No saved Brightspace session was found yet. Open the login flow and save it once before discovering courses.";
        }

        if (courseCatalogResult is null)
        {
            return "The workstation has a saved Brightspace session. Discover courses to populate the term and course selectors.";
        }

        return "Course discovery completed. Select a term and course to drive the next Brightspace workflow.";
    }

    private static string DisplayOrPlaceholder(string? value)
        => string.IsNullOrWhiteSpace(value) ? "Not available" : value;

    public void Dispose()
    {
        BrightspaceAutomationService.ActivityReported -= HandleActivityReported;
    }
}
